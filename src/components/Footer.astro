---
/**
 * Footer.astro — Site footer
 *
 * Social links, tech credits, and quick navigation.
 */
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/zelinkavo',
    icon: 'github',
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/david-oliver-16729971/',
    icon: 'linkedin',
  },
];

const navLinks = [
  { href: '/#hero', label: { es: 'Inicio', en: 'Home' } },
  { href: '/#projects', label: { es: 'Proyectos', en: 'Projects' } },
  { href: '/#skills', label: { es: 'Skills', en: 'Skills' } },
  { href: '/#experience', label: { es: 'Experiencia', en: 'Experience' } },
  { href: '/#contact', label: { es: 'Contacto', en: 'Contact' } },
];
---

<footer class="footer" role="contentinfo">
  <!-- Subtle architectural background grid -->
  <div class="footer__grid" aria-hidden="true"></div>
  
  <div class="footer__inner">
    <!-- Top section: Nav + Social -->
    <div class="footer__top">
      <!-- Quick nav links -->
      <nav class="footer__nav" aria-label={lang === 'es' ? 'Navegación del sistema' : 'System navigation'}>
        <ul class="footer__nav-list" role="list">
          {navLinks.map((item) => (
            <li>
              <a href={item.href} class="footer__nav-link">
                <span class="nav-bracket" aria-hidden="true">[</span>
                <span class="nav-text">{item.label[lang].toUpperCase()}</span>
                <span class="nav-bracket" aria-hidden="true">]</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social links -->
      <div class="footer__social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label={link.name}
          >
            <!-- Crosshairs -->
            <div class="crosshair crosshair-tl" aria-hidden="true"></div>
            <div class="crosshair crosshair-tr" aria-hidden="true"></div>
            <div class="crosshair crosshair-bl" aria-hidden="true"></div>
            <div class="crosshair crosshair-br" aria-hidden="true"></div>
            <div class="social-bg-glow" aria-hidden="true"></div>

            {link.icon === 'github' && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="footer__divider" aria-hidden="true"></div>

    <!-- Bottom: Copyright + Credits -->
    <div class="footer__bottom">
      <p class="footer__status">
        <span class="status-dot"></span>
        <span class="status-text">
          &copy; {currentYear} DO. {lang === 'es' ? 'Sistemas Operativos (All clear)' : 'Systems Operational (All clear)'}
        </span>
      </p>
      
      <div class="footer__credits">
        <span class="credits-label">SYS_ENGINE:</span>
        <span class="tech-tag">Astro 6</span>
        <span class="tech-tag">Cloudflare</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    background: transparent;
    padding: var(--space-3xl) 0 var(--space-xl);
    overflow: hidden;
  }

  .footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(212, 162, 78, 0.02) 0%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  .footer__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: linear-gradient(to bottom, black 0%, transparent 80%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%);
    z-index: 0;
    pointer-events: none;
  }

  .footer__inner {
    position: relative;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    z-index: 2;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-xl);
  }

  /* ---- Nav Links ---- */
  .footer__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl);
    list-style: none;
  }

  .footer__nav-link {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: all 0.3s ease;
  }

  .nav-bracket {
    color: rgba(255,255,255,0.2);
    transition: color 0.3s ease;
  }

  .footer__nav-link:hover {
    color: var(--color-accent-primary);
  }

  .footer__nav-link:hover .nav-bracket {
    color: var(--color-accent-primary);
  }

  /* ---- Social Links ---- */
  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s ease;
    text-decoration: none;
    border-radius: 0; /* Sharp engineering look */
  }

  .crosshair {
    position: absolute;
    width: 4px;
    height: 4px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    z-index: 10;
    transition: border-color 0.3s ease;
  }

  .crosshair-tl { top: -2px; left: -2px; border-right: none; border-bottom: none; }
  .crosshair-tr { top: -2px; right: -2px; border-left: none; border-bottom: none; }
  .crosshair-bl { bottom: -2px; left: -2px; border-right: none; border-top: none; }
  .crosshair-br { bottom: -2px; right: -2px; border-left: none; border-top: none; }

  .social-bg-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(212, 162, 78, 0.05) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }

  .footer__social-link:hover {
    color: var(--color-accent-primary);
    border-color: rgba(212, 162, 78, 0.3);
    transform: translateY(-2px);
  }

  .footer__social-link:hover .crosshair {
    border-color: var(--color-accent-primary);
  }

  .footer__social-link:hover .social-bg-glow {
    opacity: 1;
    box-shadow: 0 4px 16px rgba(212, 162, 78, 0.15);
  }

  /* ---- Divider ---- */
  .footer__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08) 20%, rgba(255,255,255,0.08) 80%, transparent);
    margin: var(--space-2xl) 0 var(--space-xl) 0;
  }

  /* ---- Bottom ---- */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer__status {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #0cce6b;
    box-shadow: 0 0 8px rgba(12, 206, 107, 0.6);
    animation: statusPulse 2s infinite ease-in-out;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(12, 206, 107, 0.6); }
    50% { opacity: 0.5; box-shadow: 0 0 2px rgba(12, 206, 107, 0.3); }
  }

  .status-text {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.05em;
  }

  .footer__credits {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .credits-label {
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.3);
    margin-right: 4px;
  }

  .tech-tag {
    position: relative;
    isolation: isolate;
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    padding: 3px 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 2px;
    cursor: default;
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .footer__top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-2xl);
    }

    .footer__nav-list {
      justify-content: center;
      gap: var(--space-md) var(--space-lg);
    }

    .footer__social {
      justify-content: center;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
      gap: var(--space-lg);
    }
    
    .footer__credits {
      justify-content: center;
    }
  }
</style>
