---
/**
 * Footer.astro — Site footer
 *
 * Social links, tech credits, and quick navigation.
 */
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/zelinkavo',
    icon: 'github',
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/in/zelinkavo',
    icon: 'linkedin',
  },
];

const navLinks = [
  { href: '#hero', label: { es: 'Inicio', en: 'Home' } },
  { href: '#projects', label: { es: 'Proyectos', en: 'Projects' } },
  { href: '#skills', label: { es: 'Skills', en: 'Skills' } },
  { href: '#experience', label: { es: 'Experiencia', en: 'Experience' } },
  { href: '#contact', label: { es: 'Contacto', en: 'Contact' } },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner">
    <!-- Top section: Nav + Social -->
    <div class="footer__top">
      <!-- Quick nav links -->
      <nav class="footer__nav" aria-label={lang === 'es' ? 'Links rápidos' : 'Quick links'}>
        <ul class="footer__nav-list" role="list">
          {navLinks.map((item) => (
            <li>
              <a href={item.href} class="footer__nav-link">
                {item.label[lang]}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Social links -->
      <div class="footer__social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-link"
            aria-label={link.name}
          >
            {link.icon === 'github' && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="footer__divider" aria-hidden="true"></div>

    <!-- Bottom: Copyright + Credits -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {currentYear} zelinkavo.
        {lang === 'es' ? 'Todos los derechos reservados.' : 'All rights reserved.'}
      </p>
      <p class="footer__credits">
        {lang === 'es' ? 'Construido con' : 'Built with'}
        <span class="footer__tech">Astro 6</span>
        +
        <span class="footer__tech">Cloudflare</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-bg-secondary);
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .footer__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-xl);
  }

  /* ---- Nav Links ---- */
  .footer__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    list-style: none;
  }

  .footer__nav-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__nav-link:hover {
    color: var(--color-text-primary);
  }

  /* ---- Social Links ---- */
  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .footer__social-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(108, 99, 255, 0.2);
  }

  /* ---- Divider ---- */
  .footer__divider {
    height: 1px;
    background: var(--color-border-subtle);
    margin: var(--space-xl) 0;
  }

  /* ---- Bottom ---- */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer__copyright {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer__credits {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer__tech {
    color: var(--color-accent-secondary);
    font-weight: 500;
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .footer__top {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__nav-list {
      justify-content: center;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
