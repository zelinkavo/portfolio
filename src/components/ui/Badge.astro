---
/**
 * Badge.astro — Pill badge component
 *
 * Color variants by cluster: ai (purple), dev (violet), infra (blue)
 * Additional: default (neutral), success (green)
 */
interface Props {
  variant?: 'default' | 'ai' | 'dev' | 'infra' | 'success';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'md', class: className } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`, `badge--${size}`, className]}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    border-radius: var(--radius-full);
    white-space: nowrap;
    line-height: 1;
  }

  /* Sizes */
  .badge--sm {
    font-size: 0.65rem;
    padding: 2px var(--space-sm);
  }

  .badge--md {
    font-size: 0.75rem;
    padding: var(--space-xs) var(--space-md);
  }

  /* Variants */
  .badge--default {
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
  }

  .badge--ai {
    color: #b4a0ff;
    background: rgba(108, 99, 255, 0.12);
    border: 1px solid rgba(108, 99, 255, 0.25);
  }

  .badge--dev {
    color: #c4a6ff;
    background: rgba(167, 139, 250, 0.12);
    border: 1px solid rgba(167, 139, 250, 0.25);
  }

  .badge--infra {
    color: #7dd3fc;
    background: rgba(56, 189, 248, 0.12);
    border: 1px solid rgba(56, 189, 248, 0.25);
  }

  .badge--success {
    color: #86efac;
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.25);
  }
</style>
