---
/**
 * SectionHeader.astro — Section title with decorative accent line
 *
 * Features: numbered sections, i18n support, gradient accent line.
 */
interface Props {
  title: string;
  subtitle?: string;
  number?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, number, align = 'left', class: className } = Astro.props;
---

<header class:list={['section-header', `section-header--${align}`, className]} data-animate="fade-up">
  {number && <span class="section-header__number">{number}</span>}
  <h2 class="section-header__title">{title}</h2>
  {subtitle && <p class="section-header__subtitle">{subtitle}</p>}
  <div class="section-header__line" aria-hidden="true"></div>
</header>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
  }

  .section-header--center {
    align-items: center;
    text-align: center;
  }

  .section-header__number {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent-primary);
    letter-spacing: 0.1em;
  }

  .section-header__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    color: var(--color-text-primary);
    line-height: 1.2;
    animation: headerFloat 10s ease-in-out infinite;
  }

  @keyframes headerFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .section-header__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 500px;
    line-height: 1.5;
  }

  .section-header__line {
    width: 48px;
    height: 3px;
    border-radius: var(--radius-full);
    background: var(--gradient-accent);
    margin-top: var(--space-xs);
    animation: lineGlow 6s ease-in-out infinite;
  }

  @keyframes lineGlow {
    0%, 100% { box-shadow: 0 0 8px rgba(212, 162, 78, 0.1); }
    50% { box-shadow: 0 0 16px rgba(212, 162, 78, 0.3); }
  }

  .section-header--center .section-header__line {
    margin-left: auto;
    margin-right: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-header__title { animation: none; }
    .section-header__line { animation: none; }
  }
</style>
