---
/**
 * Card.astro — Glassmorphism card component
 *
 * Variants: default, featured, ghost
 * If `href` is provided, renders as a link.
 */
interface Props {
  variant?: 'default' | 'featured' | 'ghost';
  href?: string;
  tag?: string;
  class?: string;
}

const { variant = 'default', href, tag, class: className } = Astro.props;

const Tag = href ? 'a' : 'div';
const linkProps = href ? { href, target: href.startsWith('http') ? '_blank' : undefined, rel: href.startsWith('http') ? 'noopener noreferrer' : undefined } : {};
---

<Tag
  class:list={['card', `card--${variant}`, className]}
  {...linkProps}
>
  <!-- Architectural crosshairs -->
  <div class="crosshair crosshair-tl" aria-hidden="true"></div>
  <div class="crosshair crosshair-tr" aria-hidden="true"></div>
  <div class="crosshair crosshair-bl" aria-hidden="true"></div>
  <div class="crosshair crosshair-br" aria-hidden="true"></div>

  {tag && <span class="card__tag">[{tag}]</span>}
  <div class="card__inner">
    <slot />
  </div>
</Tag>

<style>
  .card {
    position: relative;
    padding: var(--space-xl);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.04);
    transition: all 0.4s ease;
    text-decoration: none;
    color: inherit;
    display: block;
    border-radius: 0; /* Sharp engineering look */
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.01) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .card__inner {
    position: relative;
    z-index: 2;
  }

  .card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.01);
    transform: translateY(-2px);
  }

  .card:hover::before {
    opacity: 1;
  }

  /* Crosshairs */
  .crosshair {
    position: absolute;
    width: 6px;
    height: 6px;
    border: 1px solid var(--color-border-subtle);
    z-index: 10;
    transition: border-color var(--transition-fast);
  }

  .crosshair-tl { top: -3px; left: -3px; border-right: none; border-bottom: none; }
  .crosshair-tr { top: -3px; right: -3px; border-left: none; border-bottom: none; }
  .crosshair-bl { bottom: -3px; left: -3px; border-right: none; border-top: none; }
  .crosshair-br { bottom: -3px; right: -3px; border-left: none; border-top: none; }

  .card:hover .crosshair {
    border-color: var(--color-accent-primary);
  }

  /* Featured variant */
  .card--featured {
    border-color: rgba(212, 162, 78, 0.15);
    background: linear-gradient(145deg, rgba(212, 162, 78, 0.02) 0%, transparent 60%);
  }
  
  .card--featured .crosshair {
    border-color: rgba(212, 162, 78, 0.3);
  }

  .card--featured:hover {
    border-color: rgba(212, 162, 78, 0.4);
    background: linear-gradient(145deg, rgba(212, 162, 78, 0.05) 0%, transparent 60%);
  }

  .card--featured:hover .crosshair {
    border-color: rgba(212, 162, 78, 0.8);
    box-shadow: 0 0 8px rgba(212, 162, 78, 0.4);
  }

  /* Ghost variant */
  .card--ghost {
    background: transparent;
    border-color: transparent;
  }

  .card--ghost:hover {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .card--ghost .crosshair {
    display: none;
  }

  /* Tag badge in corner */
  .card__tag {
    position: absolute;
    top: -10px;
    right: 20px;
    background: var(--color-bg-primary); /* mask over border */
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    z-index: 5;
    transition: color 0.3s ease;
  }

  .card:hover .card__tag {
    color: var(--color-accent-secondary);
  }
</style>
