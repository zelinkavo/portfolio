---
/**
 * HeroBlock.astro — Modular hero section with parallax depth
 *
 * Features:
 * - Multi-layer parallax effect (mouse-driven)
 * - Animated grid & glow
 * - Monogram with float animation
 * - Staggered text entry
 */
---

<div class="hero" id="hero-parallax">
  <!-- Background layers for parallax depth -->
  <div class="hero__layer hero__layer--bg" data-depth="0.02">
    <div class="hero__grid" aria-hidden="true"></div>
  </div>

  <div class="hero__layer hero__layer--mid" data-depth="0.05">
    <div class="hero__glow" aria-hidden="true"></div>
    <!-- Floating particles -->
    <div class="hero__particles" aria-hidden="true">
      <span class="hero__particle" style="--x: 15%; --y: 25%; --size: 3px; --delay: 0s;"></span>
      <span class="hero__particle" style="--x: 80%; --y: 30%; --size: 2px; --delay: 1.2s;"></span>
      <span class="hero__particle" style="--x: 25%; --y: 70%; --size: 4px; --delay: 0.7s;"></span>
      <span class="hero__particle" style="--x: 70%; --y: 65%; --size: 2px; --delay: 2s;"></span>
      <span class="hero__particle" style="--x: 50%; --y: 15%; --size: 3px; --delay: 1.5s;"></span>
      <span class="hero__particle" style="--x: 90%; --y: 75%; --size: 2px; --delay: 0.3s;"></span>
    </div>
  </div>

  <div class="hero__layer hero__layer--fg" data-depth="0.08">
    <div class="hero__content">
      <div class="hero__monogram" data-animate="scale-in">
        <span class="hero__monogram-text" aria-hidden="true">DO</span>
      </div>

      <div class="hero__title-block">
        <p class="hero__greeting" data-animate="fade-up" style="--stagger-index: 0">David Oliver</p>
        <h1 class="hero__title" data-animate="fade-up" style="--stagger-index: 1">
          Senior Full Stack Developer
          <span class="hero__amp">&</span>
          AI Solutions Engineer
        </h1>
        <p class="hero__tagline" data-animate="fade-up" style="--stagger-index: 2">
          Orquestador de sistemas autónomos y ecosistemas digitales
        </p>
      </div>

      <!-- Tech stack -->
      <div class="hero__stack">
        {['Python', 'TypeScript', 'React', 'Docker', 'Cloudflare'].map((tech, i) => (
          <span class="hero__stack-item" style={`--stagger-index: ${i + 3}`} data-animate="fade-up">
            {tech}
          </span>
        ))}
      </div>

      <!-- Scroll indicator -->
      <div class="hero__scroll" data-animate="fade-in" style="--stagger-index: 5" aria-hidden="true">
        <div class="hero__scroll-line"></div>
      </div>
    </div>
  </div>
</div>

<script>
  function initParallax() {
    const hero = document.getElementById('hero-parallax');
    if (!hero || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const layers = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let ticking = false;

    hero.addEventListener('mousemove', (e) => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const rect = hero.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
        const y = (e.clientY - rect.top - rect.height / 2) / rect.height;

        layers.forEach((layer) => {
          const depth = parseFloat(layer.dataset.depth || '0');
          const moveX = x * depth * 100;
          const moveY = y * depth * 100;
          layer.style.transform = `translate(${moveX}px, ${moveY}px)`;
        });
        ticking = false;
      });
    });

    hero.addEventListener('mouseleave', () => {
      layers.forEach((layer) => {
        layer.style.transform = 'translate(0, 0)';
      });
    });
  }

  document.addEventListener('astro:page-load', initParallax);
  initParallax();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    padding: var(--space-3xl) var(--space-xl);
    overflow: hidden;
  }

  /* Parallax layers */
  .hero__layer {
    position: absolute;
    inset: -20px; /* extra space for parallax movement */
    transition: transform 0.15s ease-out;
  }

  .hero__layer--fg {
    position: relative;
    inset: auto;
    z-index: 2;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, rgba(212, 162, 78, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 65%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 65%);
  }

  .hero__glow {
    position: absolute;
    width: 600px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse,
      rgba(212, 162, 78, 0.06) 0%,
      rgba(91, 184, 166, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Floating particles */
  .hero__particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: var(--color-accent-primary);
    opacity: 0.3;
    animation: particleFloat 4s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes particleFloat {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50% { transform: translateY(-12px); opacity: 0.6; }
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
    max-width: 640px;
  }

  .hero__monogram {
    width: 88px;
    height: 88px;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-accent-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-secondary);
    box-shadow: var(--shadow-glow);
    animation: monogramFloat 6s ease-in-out infinite;
  }

  @keyframes monogramFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .hero__monogram-text {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-accent-primary);
  }

  .hero__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .hero__amp {
    display: block;
    font-size: 0.6em;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: var(--space-xs) 0;
  }

  .hero__tagline {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 440px;
    line-height: 1.7;
    margin: 0 auto;
  }

  .hero__stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .hero__stack-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    letter-spacing: 0.02em;
  }

  .hero__stack-item:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
  }

  /* Scroll indicator */
  .hero__scroll {
    margin-top: var(--space-lg);
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-accent-primary), transparent);
    margin: 0 auto;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 0.8; transform: scaleY(1.2); }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) var(--space-md);
    }
    .hero__monogram {
      width: 72px;
      height: 72px;
    }
    .hero__monogram-text {
      font-size: 1.6rem;
    }
    .hero__particles {
      display: none;
    }
  }
</style>
