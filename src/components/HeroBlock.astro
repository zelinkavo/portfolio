---
/**
 * HeroBlock.astro — Hero section with strong parallax & atmosphere
 *
 * Multi-layer depth effect, prominent grid, animated orbs,
 * floating monogram, gradient accent line.
 */
---

<div class="hero" id="hero-parallax">
  <!-- Layer 1: Grid background -->
  <div class="hero__layer" data-depth="0.02">
    <div class="hero__grid" aria-hidden="true"></div>
  </div>

  <!-- Layer 2: Orbs & atmosphere -->
  <div class="hero__layer" data-depth="0.04">
    <div class="hero__orb hero__orb--gold" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--teal" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--steel" aria-hidden="true"></div>
  </div>

  <!-- Layer 3: Content -->
  <div class="hero__layer hero__layer--content" data-depth="0.07">
    <div class="hero__content">
      <div class="hero__monogram" data-animate="scale-in">
        <span class="hero__monogram-text" aria-hidden="true">DO</span>
      </div>

      <div class="hero__title-block">
        <p class="hero__greeting" data-animate="fade-up" style="--stagger-index: 0">David Oliver</p>
        <h1 class="hero__title" data-animate="fade-up" style="--stagger-index: 1">
          Senior Full Stack Developer
          <span class="hero__amp">&</span>
          AI Solutions Engineer
        </h1>
        <p class="hero__tagline" data-animate="fade-up" style="--stagger-index: 2">
          Orquestador de sistemas autónomos y ecosistemas digitales
        </p>
      </div>

      <div class="hero__stack">
        {['Python', 'TypeScript', 'React', 'Docker', 'Cloudflare'].map((tech, i) => (
          <span class="hero__stack-item" style={`--stagger-index: ${i + 3}`} data-animate="fade-up">
            {tech}
          </span>
        ))}
      </div>

      <div class="hero__scroll-cta" data-animate="fade-in" style="--stagger-index: 6" aria-hidden="true">
        <span class="hero__scroll-text">scroll</span>
        <div class="hero__scroll-line"></div>
      </div>
    </div>
  </div>

  <!-- Gradient accent line at bottom -->
  <div class="hero__accent-line" aria-hidden="true"></div>
</div>

<script>
  function initParallax() {
    const hero = document.getElementById('hero-parallax');
    if (!hero || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth < 768) return; // Skip on mobile

    const layers = hero.querySelectorAll<HTMLElement>('[data-depth]');
    let rafId: number;

    hero.addEventListener('mousemove', (e) => {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        const rect = hero.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
        const y = (e.clientY - rect.top - rect.height / 2) / rect.height;

        layers.forEach((layer) => {
          const depth = parseFloat(layer.dataset.depth || '0');
          const moveX = x * depth * 120;
          const moveY = y * depth * 80;
          layer.style.transform = `translate(${moveX}px, ${moveY}px)`;
        });
      });
    });

    hero.addEventListener('mouseleave', () => {
      layers.forEach((layer) => {
        layer.style.transform = 'translate(0, 0)';
      });
    });
  }

  document.addEventListener('astro:page-load', initParallax);
  initParallax();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    padding: var(--space-3xl) var(--space-xl);
    overflow: hidden;
  }

  .hero__layer {
    position: absolute;
    inset: -30px;
    transition: transform 0.2s ease-out;
    pointer-events: none;
  }

  .hero__layer--content {
    position: relative;
    inset: auto;
    pointer-events: auto;
    z-index: 2;
  }

  /* Grid — more visible now */
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 162, 78, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 162, 78, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 70%);
  }

  /* Orbs — visible ambient light sources */
  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero__orb--gold {
    width: 500px;
    height: 400px;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(212, 162, 78, 0.08);
    animation: orbPulse 8s ease-in-out infinite;
  }

  .hero__orb--teal {
    width: 300px;
    height: 300px;
    bottom: 15%;
    left: 10%;
    background: rgba(91, 184, 166, 0.05);
    animation: orbPulse 10s ease-in-out infinite 2s;
  }

  .hero__orb--steel {
    width: 350px;
    height: 250px;
    top: 30%;
    right: 5%;
    background: rgba(124, 149, 196, 0.05);
    animation: orbPulse 9s ease-in-out infinite 4s;
  }

  @keyframes orbPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }

  .hero__orb--gold {
    animation-name: orbPulseGold;
  }

  @keyframes orbPulseGold {
    0%, 100% { opacity: 1; transform: translateX(-50%) scale(1); }
    50% { opacity: 0.6; transform: translateX(-50%) scale(1.1); }
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
    max-width: 640px;
  }

  .hero__monogram {
    width: 88px;
    height: 88px;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-accent-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-secondary);
    box-shadow: var(--shadow-glow), inset 0 0 20px rgba(212, 162, 78, 0.05);
    animation: monogramFloat 6s ease-in-out infinite;
  }

  @keyframes monogramFloat {
    0%, 100% { transform: translateY(0); box-shadow: var(--shadow-glow), inset 0 0 20px rgba(212, 162, 78, 0.05); }
    50% { transform: translateY(-8px); box-shadow: var(--shadow-glow-strong), inset 0 0 20px rgba(212, 162, 78, 0.08); }
  }

  .hero__monogram-text {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-accent-primary);
  }

  .hero__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .hero__amp {
    display: block;
    font-size: 0.6em;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: var(--space-xs) 0;
  }

  .hero__tagline {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 440px;
    line-height: 1.7;
    margin: 0 auto;
  }

  .hero__stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .hero__stack-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    background: rgba(17, 20, 26, 0.6);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
  }

  .hero__stack-item:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    box-shadow: 0 0 16px rgba(212, 162, 78, 0.1);
  }

  /* Scroll CTA */
  .hero__scroll-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .hero__scroll-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-accent-primary), transparent);
    animation: scrollPulse 2.5s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; height: 48px; }
    50% { opacity: 0.8; height: 56px; }
  }

  /* Accent line */
  .hero__accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-accent-primary) 20%,
      var(--color-accent-secondary) 50%,
      var(--color-accent-tertiary) 80%,
      transparent 100%
    );
    opacity: 0.3;
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) var(--space-md);
    }
    .hero__monogram {
      width: 72px;
      height: 72px;
    }
    .hero__monogram-text {
      font-size: 1.6rem;
    }
    .hero__orb--teal,
    .hero__orb--steel {
      display: none;
    }
    .hero__orb--gold {
      width: 300px;
      height: 250px;
    }
  }
</style>
