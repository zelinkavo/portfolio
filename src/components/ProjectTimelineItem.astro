---
interface Props {
  title: string;
  isOpen?: boolean;
}

const { title, isOpen = false } = Astro.props;
---

<div class="pt-item" data-animate="fade-up">
  <div class="pt-marker">
    <div class:list={['pt-dot', { 'pt-dot--active': isOpen }]}></div>
    <div class="pt-line" aria-hidden="true"></div>
  </div>
  <div class="pt-content">
    <details class="pt-details" open={isOpen}>
      <summary class="pt-summary">
        <h2 class="pt-title">{title}</h2>
        <span class="pt-toggle" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </summary>
      <div class="pt-body">
        <slot />
      </div>
    </details>
  </div>
</div>

<style>
  .pt-item {
    display: flex;
    gap: var(--space-xl);
    position: relative;
  }

  /* Target the last item to hide the timeline line */
  .pt-item:last-child .pt-line {
    display: none;
  }

  /* Marker */
  .pt-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 24px;
  }

  .pt-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--color-text-muted);
    background: var(--color-bg-primary);
    flex-shrink: 0;
    margin-top: 32px; /* Approx center of summary padding top + h2 height */
    z-index: 1;
    transition: all var(--transition-fast);
  }

  .pt-dot--active {
    border-color: var(--color-accent-primary);
    background: var(--color-accent-primary);
    box-shadow: 0 0 12px rgba(212, 162, 78, 0.4);
  }

  .pt-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--color-border-subtle), transparent);
    min-height: var(--space-2xl);
  }

  /* Content */
  .pt-content {
    flex: 1;
    min-width: 0;
    padding-bottom: var(--space-2xl);
  }

  .pt-item:last-child .pt-content {
    padding-bottom: 0;
  }

  /* Details Box */
  .pt-details {
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .pt-details[open] {
    background: var(--color-bg-card);
    border-color: var(--color-border-subtle);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  .pt-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    transition: background var(--transition-fast);
  }

  .pt-summary::-webkit-details-marker {
    display: none;
  }

  .pt-summary::marker {
    content: '';
  }

  .pt-summary:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .pt-details[open] .pt-summary:hover {
    background: transparent;
  }

  .pt-title {
    font-size: 1.75rem;
    color: var(--color-text-primary);
    margin: 0;
    font-weight: 600;
  }

  .pt-toggle {
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .pt-details[open] .pt-toggle {
    transform: rotate(180deg);
  }

  .pt-body {
    padding: 0 var(--space-xl) var(--space-xl);
    animation: slideDown 0.3s ease-out;
  }

  /* Line separator inside body similar to old h2 border bottom */
  .pt-body::before {
    content: '';
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-border-subtle);
    margin-bottom: var(--space-lg);
    margin-top: calc(var(--space-xs) * -1);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .pt-item {
      gap: var(--space-md);
    }
    .pt-summary {
      padding: var(--space-lg);
    }
    .pt-body {
      padding: 0 var(--space-lg) var(--space-lg);
    }
    .pt-dot {
      margin-top: 26px;
    }
    .pt-title {
      font-size: 1.5rem;
    }
  }
</style>
