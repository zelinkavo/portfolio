---
/**
 * Index — Portfolio Senior 2026
 *
 * "The Orchestrator" — Personal portfolio with warm palette,
 * distinctive design, real content.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoLayout from '../layouts/BentoLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import SkillsRadar from '../components/interactive/SkillsRadar';
import { projects } from '../data/projects';
import { skillClusters } from '../data/skills';
---

<BaseLayout
  title="David Oliver — Senior Full Stack Developer & AI Solutions Engineer"
  description="Orquestador de sistemas autónomos y ecosistemas digitales. Portfolio técnico 2026."
>
  <!-- ==================== HERO ==================== -->
  <section id="hero" data-animate="fade-in">
    <HeroBlock />
  </section>

  <BentoLayout>
    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" slot="projects" class="section--projects">
      <SectionHeader
        number="01."
        title="Proyectos"
        subtitle="Casos reales con impacto medible"
      />

      <div class="projects-grid">
        {projects.filter(p => p.featured).map((project, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <Card variant={project.order === 1 ? 'featured' : 'default'} tag={project.category} href={`/projects/${project.slug}`}>
              <div class="project-card">
                <div class="project-card__category">
                  <span class="project-card__icon" aria-hidden="true">
                    {project.category === 'ai' ? '⚙️' : project.category === 'mobile' ? '📱' : project.category === 'gamedev' ? '🎮' : '🔧'}
                  </span>
                  <Badge variant={project.category === 'ai' ? 'ai' : project.category === 'mobile' ? 'dev' : project.category === 'devops' ? 'infra' : 'default'} size="sm">
                    {project.category}
                  </Badge>
                </div>
                <h3 class="project-card__title">{project.title.es}</h3>
                <p class="project-card__subtitle">{project.subtitle.es}</p>
                <div class="project-card__techs">
                  {project.technologies.slice(0, 4).map(tech => (
                    <span class="project-card__tech">{tech}</span>
                  ))}
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" slot="skills" class="section--skills">
      <SectionHeader
        number="02."
        title="Skills"
        subtitle="Clusters semánticos"
      />

      <div data-animate="fade-up" style="--stagger-index: 1">
        <SkillsRadar
          client:visible
          clusters={skillClusters.map(c => ({
            id: c.id,
            label: c.title.es,
            color: c.color,
            skills: c.skills.map(s => ({ name: s.name, level: s.level, cluster: s.cluster })),
          }))}
        />
      </div>

      <noscript>
        <div class="skills-list">
          {skillClusters.map((cluster, ci) => (
            <div class="skills-cluster" data-animate="fade-up" style={`--stagger-index: ${ci}`}>
              <h3 class="skills-cluster__title">
                <span class="skills-cluster__dot" style={`background: ${cluster.color}`} aria-hidden="true"></span>
                {cluster.title.es}
              </h3>
              <div class="skills-cluster__tags">
                {cluster.skills.map(skill => (
                  <Badge variant={cluster.id === 'ai' ? 'ai' : cluster.id === 'development' ? 'dev' : 'infra'} size="sm">
                    {skill.name}
                  </Badge>
                ))}
              </div>
            </div>
          ))}
        </div>
      </noscript>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" slot="experience" class="section--experience">
      <SectionHeader
        number="03."
        title="Experiencia"
        subtitle="+12 años construyendo software"
      />
      <ExperienceTimeline />
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section id="contact" slot="contact" class="section--contact">
      <SectionHeader
        number="04."
        title="Contacto"
        subtitle="Hablemos"
        align="center"
      />

      <div class="contact-links" data-animate="fade-up">
        <a
          href="https://github.com/zelinkavo"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="GitHub"
          id="contact-github"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/david-oliver-16729971/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="LinkedIn"
          id="contact-linkedin"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </BentoLayout>
</BaseLayout>

<style>
  /* ==================== SECTIONS BASE ==================== */
  section {
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
    position: relative;
    overflow: hidden;
  }

  section#hero {
    padding-top: 0;
    padding-bottom: 0;
    overflow: visible;
  }

  /* Gradient dividers between sections */
  section:not(#hero)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(80%, 600px);
    height: 1px;
    background: linear-gradient(
      90deg, transparent,
      rgba(212, 162, 78, 0.18) 30%,
      rgba(124, 149, 196, 0.18) 70%,
      transparent
    );
  }

  /* ==================== SECTION BACKGROUNDS ==================== */
  /* Each section gets a unique pattern using CSS only.
     These are structural (dot grids, line patterns) rather than
     generic blob gradients. */

  /* Projects — dot grid + corner brackets */
  .section--projects::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle, rgba(212, 162, 78, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, transparent 95%, rgba(212, 162, 78, 0.04) 95%),
      linear-gradient(transparent 95%, rgba(212, 162, 78, 0.04) 95%);
    background-size: 40px 40px, 40px 40px, 40px 40px;
    mask-image: linear-gradient(135deg, rgba(0,0,0,0.6) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.3) 100%);
    -webkit-mask-image: linear-gradient(135deg, rgba(0,0,0,0.6) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Skills — concentric ring pattern */
  .section--skills::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 700px;
    height: 700px;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(circle, transparent 98px, rgba(124, 149, 196, 0.06) 100px, transparent 102px),
      radial-gradient(circle, transparent 198px, rgba(124, 149, 196, 0.04) 200px, transparent 202px),
      radial-gradient(circle, transparent 298px, rgba(124, 149, 196, 0.03) 300px, transparent 302px);
    pointer-events: none;
    z-index: 0;
  }

  /* Experience — vertical dashed guides with glow */
  .section--experience::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(91, 184, 166, 0.08), transparent 15%, transparent 85%, rgba(91, 184, 166, 0.06)),
      repeating-linear-gradient(
        to bottom,
        rgba(91, 184, 166, 0.06) 0px,
        rgba(91, 184, 166, 0.06) 4px,
        transparent 4px,
        transparent 16px
      );
    background-size: 100% 100%, 1px 100%;
    background-position: 0 0, 60px 0;
    mask-image: linear-gradient(to right, rgba(0,0,0,0.5) 0%, transparent 10%);
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0.5) 0%, transparent 10%);
    pointer-events: none;
    z-index: 0;
  }

  /* Contact — converging lines */
  .section--contact::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, transparent 40%, rgba(212, 162, 78, 0.03) 50%, transparent 60%),
      linear-gradient(200deg, transparent 40%, rgba(212, 162, 78, 0.03) 50%, transparent 60%),
      radial-gradient(ellipse at 50% 50%, rgba(212, 162, 78, 0.06) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ==================== PROJECTS ==================== */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__category {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.1rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  .project-card__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  /* ==================== SKILLS (noscript) ==================== */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .skills-cluster {
    border-left: 2px solid var(--color-border-subtle);
    padding-left: var(--space-lg);
  }

  .skills-cluster__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .skills-cluster__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skills-cluster__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== CONTACT ==================== */
  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-2xl);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-base);
    min-width: 160px;
    position: relative;
    overflow: hidden;
  }

  .contact-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(212, 162, 78, 0.12);
  }

  .contact-link span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .contact-link {
      flex: 1;
      min-width: 120px;
      padding: var(--space-lg) var(--space-xl);
    }
    /* Reduce section patterns on mobile */
    .section--projects::after,
    .section--skills::after,
    .section--experience::after,
    .section--contact::after {
      opacity: 0.4;
    }
  }
</style>
