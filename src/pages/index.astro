---
/**
 * Index — Portfolio Senior 2026
 *
 * "The Orchestrator" — Personal portfolio with warm palette,
 * distinctive design, real content.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoLayout from '../layouts/BentoLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import { projects } from '../data/projects';
import { skillClusters } from '../data/skills';
---

<BaseLayout
  title="David Oliver — Senior Full Stack Developer & AI Solutions Engineer"
  description="Orquestador de sistemas autónomos y ecosistemas digitales. Portfolio técnico 2026."
>
  <!-- ==================== HERO ==================== -->
  <section id="hero" data-animate="fade-in">
    <HeroBlock />
  </section>

  <BentoLayout>
    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" slot="projects">
      <SectionHeader
        number="01."
        title="Proyectos"
        subtitle="Casos reales con impacto medible"
      />

      <div class="projects-grid">
        {projects.filter(p => p.featured).map((project, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <Card variant={project.order === 1 ? 'featured' : 'default'} tag={project.category} href={`/projects/${project.slug}`}>
              <div class="project-card">
                <div class="project-card__category">
                  <span class="project-card__icon" aria-hidden="true">
                    {project.category === 'ai' ? '⚙️' : project.category === 'mobile' ? '📱' : project.category === 'gamedev' ? '🎮' : '🔧'}
                  </span>
                  <Badge variant={project.category === 'ai' ? 'ai' : project.category === 'mobile' ? 'dev' : project.category === 'devops' ? 'infra' : 'default'} size="sm">
                    {project.category}
                  </Badge>
                </div>
                <h3 class="project-card__title">{project.title.es}</h3>
                <p class="project-card__subtitle">{project.subtitle.es}</p>
                <div class="project-card__techs">
                  {project.technologies.slice(0, 4).map(tech => (
                    <span class="project-card__tech">{tech}</span>
                  ))}
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" slot="skills">
      <SectionHeader
        number="02."
        title="Skills"
        subtitle="Clusters semánticos"
      />

      <div class="skills-list">
        {skillClusters.map((cluster, ci) => (
          <div class="skills-cluster" data-animate="fade-up" style={`--stagger-index: ${ci}`}>
            <h3 class="skills-cluster__title">
              <span class="skills-cluster__dot" style={`background: ${cluster.color}`} aria-hidden="true"></span>
              {cluster.title.es}
            </h3>
            <div class="skills-cluster__tags">
              {cluster.skills.map(skill => (
                <Badge variant={cluster.id === 'ai' ? 'ai' : cluster.id === 'development' ? 'dev' : 'infra'} size="sm">
                  {skill.name}
                </Badge>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" slot="experience">
      <SectionHeader
        number="03."
        title="Experiencia"
        subtitle="+12 años construyendo software"
      />
      <ExperienceTimeline />
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section id="contact" slot="contact">
      <SectionHeader
        number="04."
        title="Contacto"
        subtitle="Hablemos"
        align="center"
      />

      <div class="contact-links" data-animate="fade-up">
        <a
          href="https://github.com/zelinkavo"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="GitHub"
          id="contact-github"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/david-oliver-16729971/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="LinkedIn"
          id="contact-linkedin"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </BentoLayout>
</BaseLayout>

<style>
  /* ==================== PROJECTS ==================== */
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: var(--bento-gap);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__category {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.1rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    color: var(--color-text-primary);
  }

  .project-card__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  /* ==================== SKILLS ==================== */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .skills-cluster {
    border-left: 2px solid var(--color-border-subtle);
    padding-left: var(--space-lg);
  }

  .skills-cluster__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .skills-cluster__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skills-cluster__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== CONTACT ==================== */
  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-base);
    min-width: 140px;
  }

  .contact-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(212, 162, 78, 0.10);
  }

  .contact-link span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ==================== SECTIONS SPACING ==================== */
  section {
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
  }

  section#hero {
    padding-top: 0;
    padding-bottom: 0;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 640px) {
    .contact-link {
      flex: 1;
      min-width: 120px;
    }
  }
</style>
