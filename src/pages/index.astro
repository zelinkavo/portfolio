---
/**
 * Index — Portfolio Senior 2026
 *
 * "The Orchestrator" — Personal portfolio with warm palette,
 * distinctive design, real content.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoLayout from '../layouts/BentoLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import SkillsRadar from '../components/interactive/SkillsRadar';
import { projects } from '../data/projects';
import { skillClusters } from '../data/skills';
---

<BaseLayout
  title="David Oliver — Senior Full Stack Developer & AI Solutions Engineer"
  description="Orquestador de sistemas autónomos y ecosistemas digitales. Portfolio técnico 2026."
>
  <!-- ==================== HERO ==================== -->
  <section id="hero" data-animate="fade-in">
    <HeroBlock />
  </section>

  <BentoLayout>
    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" slot="projects" class="section--themed">
      <div class="section__bg section__bg--projects" aria-hidden="true">
        <div class="section__grid"></div>
        <div class="section__orb section__orb--gold-right"></div>
        <div class="section__orb section__orb--gold-left"></div>
        <div class="mote mote--gold" style="top:15%;left:12%;--mote-dur:18s;--mote-dx:20px;--mote-dy:-15px"></div>
        <div class="mote mote--gold" style="top:55%;right:18%;--mote-dur:22s;--mote-dx:-12px;--mote-dy:18px;animation-delay:-5s"></div>
        <div class="mote mote--gold" style="top:75%;left:40%;--mote-dur:16s;--mote-dx:15px;--mote-dy:-10px;animation-delay:-8s"></div>
        <div class="mote mote--gold mote--lg" style="top:30%;right:35%;--mote-dur:24s;--mote-dx:-8px;--mote-dy:12px;animation-delay:-12s"></div>
        <div class="mote mote--gold" style="top:45%;left:65%;--mote-dur:20s;--mote-dx:-18px;--mote-dy:-12px;animation-delay:-3s"></div>
      </div>

      <SectionHeader
        number="01."
        title="Proyectos"
        subtitle="Casos reales con impacto medible"
      />

      <div class="projects-grid">
        {projects.filter(p => p.featured).map((project, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <Card variant={project.order === 1 ? 'featured' : 'default'} tag={project.category} href={`/projects/${project.slug}`}>
              <div class="project-card">
                <div class="project-card__category">
                  <span class="project-card__icon" aria-hidden="true">
                    {project.category === 'ai' ? '⚙️' : project.category === 'mobile' ? '📱' : project.category === 'gamedev' ? '🎮' : '🔧'}
                  </span>
                  <Badge variant={project.category === 'ai' ? 'ai' : project.category === 'mobile' ? 'dev' : project.category === 'devops' ? 'infra' : 'default'} size="sm">
                    {project.category}
                  </Badge>
                </div>
                <h3 class="project-card__title">{project.title.es}</h3>
                <p class="project-card__subtitle">{project.subtitle.es}</p>
                <div class="project-card__techs">
                  {project.technologies.slice(0, 4).map(tech => (
                    <span class="project-card__tech">{tech}</span>
                  ))}
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" slot="skills" class="section--themed">
      <div class="section__bg section__bg--skills" aria-hidden="true">
        <div class="section__grid section__grid--sparse"></div>
        <div class="section__orb section__orb--steel-left"></div>
        <div class="mote mote--steel" style="top:20%;right:15%;--mote-dur:20s;--mote-dx:-18px;--mote-dy:12px"></div>
        <div class="mote mote--steel" style="top:60%;left:25%;--mote-dur:25s;--mote-dx:14px;--mote-dy:-16px;animation-delay:-7s"></div>
        <div class="mote mote--steel mote--lg" style="top:40%;right:40%;--mote-dur:18s;--mote-dx:-10px;--mote-dy:20px;animation-delay:-3s"></div>
        <div class="mote mote--steel" style="top:80%;left:60%;--mote-dur:22s;--mote-dx:16px;--mote-dy:-8px;animation-delay:-11s"></div>
      </div>

      <SectionHeader
        number="02."
        title="Skills"
        subtitle="Clusters semánticos"
      />

      <div data-animate="fade-up" style="--stagger-index: 1">
        <SkillsRadar
          client:visible
          clusters={skillClusters.map(c => ({
            id: c.id,
            label: c.title.es,
            color: c.color,
            skills: c.skills.map(s => ({ name: s.name, level: s.level, cluster: s.cluster })),
          }))}
        />
      </div>

      <noscript>
        <div class="skills-list">
          {skillClusters.map((cluster, ci) => (
            <div class="skills-cluster" data-animate="fade-up" style={`--stagger-index: ${ci}`}>
              <h3 class="skills-cluster__title">
                <span class="skills-cluster__dot" style={`background: ${cluster.color}`} aria-hidden="true"></span>
                {cluster.title.es}
              </h3>
              <div class="skills-cluster__tags">
                {cluster.skills.map(skill => (
                  <Badge variant={cluster.id === 'ai' ? 'ai' : cluster.id === 'development' ? 'dev' : 'infra'} size="sm">
                    {skill.name}
                  </Badge>
                ))}
              </div>
            </div>
          ))}
        </div>
      </noscript>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" slot="experience" class="section--themed">
      <div class="section__bg section__bg--experience" aria-hidden="true">
        <div class="section__grid section__grid--sparse"></div>
        <div class="section__orb section__orb--teal-right"></div>
        <div class="mote mote--teal" style="top:10%;left:20%;--mote-dur:19s;--mote-dx:16px;--mote-dy:-14px;animation-delay:-2s"></div>
        <div class="mote mote--teal" style="top:50%;right:12%;--mote-dur:24s;--mote-dx:-14px;--mote-dy:16px;animation-delay:-9s"></div>
        <div class="mote mote--teal mote--lg" style="top:70%;left:50%;--mote-dur:21s;--mote-dx:10px;--mote-dy:-18px;animation-delay:-6s"></div>
      </div>

      <SectionHeader
        number="03."
        title="Experiencia"
        subtitle="+12 años construyendo software"
      />
      <ExperienceTimeline />
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section id="contact" slot="contact" class="section--themed">
      <div class="section__bg section__bg--contact" aria-hidden="true">
        <div class="section__grid section__grid--fine"></div>
        <div class="section__orb section__orb--gold-center"></div>
        <div class="mote mote--gold" style="top:25%;left:30%;--mote-dur:17s;--mote-dx:12px;--mote-dy:-10px;animation-delay:-4s"></div>
        <div class="mote mote--gold" style="top:60%;right:25%;--mote-dur:21s;--mote-dx:-16px;--mote-dy:14px;animation-delay:-10s"></div>
        <div class="mote mote--gold mote--lg" style="top:45%;left:65%;--mote-dur:25s;--mote-dx:8px;--mote-dy:-12px;animation-delay:-14s"></div>
      </div>

      <SectionHeader
        number="04."
        title="Contacto"
        subtitle="Hablemos"
        align="center"
      />

      <div class="contact-links" data-animate="fade-up">
        <a
          href="https://github.com/zelinkavo"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="GitHub"
          id="contact-github"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/david-oliver-16729971/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="LinkedIn"
          id="contact-linkedin"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </BentoLayout>
</BaseLayout>

<style>
  /* ==================== SECTION FOUNDATIONS ==================== */
  section {
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
    position: relative;
  }

  section#hero {
    padding-top: 0;
    padding-bottom: 0;
  }

  /* Gradient dividers between sections */
  section:not(#hero)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: 1px;
    background: linear-gradient(
      90deg, transparent 5%,
      rgba(212, 162, 78, 0.12) 30%,
      rgba(124, 149, 196, 0.10) 70%,
      transparent 95%
    );
  }

  /* ==================== FULL-BLEED SECTION BACKGROUNDS ====================
   * The section__bg div breaks out of the max-width container using
   * viewport-width calc, giving full-bleed backgrounds while keeping
   * content constrained. Same approach as the hero grid/orbs.
   */
  .section__bg {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Grid pattern — coherent with hero, fading gradually per section */
  .section__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 162, 78, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 162, 78, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 15%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 15%, transparent 70%);
  }

  .section__grid--sparse {
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 10%, transparent 65%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 10%, transparent 65%);
  }

  .section__grid--fine {
    background-size: 32px 32px;
    background-image:
      linear-gradient(rgba(212, 162, 78, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 162, 78, 0.025) 1px, transparent 1px);
  }

  /* Grid colors per section — gradual fade */
  .section__bg--skills .section__grid {
    background-image:
      linear-gradient(rgba(124, 149, 196, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124, 149, 196, 0.035) 1px, transparent 1px);
  }

  .section__bg--experience .section__grid {
    background-image:
      linear-gradient(rgba(91, 184, 166, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(91, 184, 166, 0.03) 1px, transparent 1px);
  }

  /* Ambient orbs — visible, gradual degradation hero → contact */
  .section__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  /* Projects — subtle ambient tint, orbs are background atmosphere */
  .section__orb--gold-right {
    width: 600px;
    height: 500px;
    top: 10%;
    right: 0%;
    background: rgba(212, 162, 78, 0.07);
    animation: sectionOrbFloat 16s ease-in-out infinite;
  }

  .section__orb--gold-left {
    width: 450px;
    height: 400px;
    bottom: 10%;
    left: 5%;
    background: rgba(212, 162, 78, 0.05);
    animation: sectionOrbFloat 20s ease-in-out infinite 8s;
  }

  /* Skills */
  .section__orb--steel-left {
    width: 550px;
    height: 450px;
    top: 15%;
    left: 0%;
    background: rgba(124, 149, 196, 0.06);
    animation: sectionOrbFloat 18s ease-in-out infinite 3s;
  }

  /* Experience */
  .section__orb--teal-right {
    width: 500px;
    height: 400px;
    top: 20%;
    right: 5%;
    background: rgba(91, 184, 166, 0.05);
    animation: sectionOrbFloat 20s ease-in-out infinite 5s;
  }

  /* Contact */
  .section__orb--gold-center {
    width: 450px;
    height: 380px;
    top: 25%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(212, 162, 78, 0.04);
    animation: sectionOrbPulse 12s ease-in-out infinite;
  }

  @keyframes sectionOrbFloat {
    0%   { transform: translate(0, 0); opacity: 1; }
    33%  { transform: translate(15px, -20px); opacity: 0.65; }
    66%  { transform: translate(-12px, -8px); opacity: 0.8; }
    100% { transform: translate(0, 0); opacity: 1; }
  }

  @keyframes sectionOrbPulse {
    0%   { transform: translateX(-50%) scale(1); opacity: 0.8; }
    50%  { transform: translateX(-50%) scale(1.15); opacity: 0.45; }
    100% { transform: translateX(-50%) scale(1); opacity: 0.8; }
  }

  /* Floating motes — small drifting dots for organic life */
  .mote {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    animation: moteDrift var(--mote-dur, 20s) ease-in-out infinite;
    pointer-events: none;
  }

  .mote--lg {
    width: 5px;
    height: 5px;
  }

  .mote--gold {
    background: rgba(212, 162, 78, 0.5);
    box-shadow: 0 0 12px rgba(212, 162, 78, 0.25);
  }
  .mote--gold.mote--lg {
    background: rgba(212, 162, 78, 0.4);
    box-shadow: 0 0 20px rgba(212, 162, 78, 0.2);
  }

  .mote--steel {
    background: rgba(124, 149, 196, 0.5);
    box-shadow: 0 0 12px rgba(124, 149, 196, 0.25);
  }
  .mote--steel.mote--lg {
    background: rgba(124, 149, 196, 0.4);
    box-shadow: 0 0 20px rgba(124, 149, 196, 0.2);
  }

  .mote--teal {
    background: rgba(91, 184, 166, 0.5);
    box-shadow: 0 0 12px rgba(91, 184, 166, 0.25);
  }
  .mote--teal.mote--lg {
    background: rgba(91, 184, 166, 0.4);
    box-shadow: 0 0 20px rgba(91, 184, 166, 0.2);
  }

  @keyframes moteDrift {
    0%   { transform: translate(0, 0); opacity: 0.5; }
    25%  { transform: translate(var(--mote-dx, 10px), var(--mote-dy, -10px)); opacity: 1; }
    50%  { transform: translate(calc(var(--mote-dx, 10px) * -0.5), calc(var(--mote-dy, -10px) * 0.7)); opacity: 0.6; }
    75%  { transform: translate(calc(var(--mote-dx, 10px) * 0.3), calc(var(--mote-dy, -10px) * -0.4)); opacity: 1; }
    100% { transform: translate(0, 0); opacity: 0.5; }
  }

  /* Content sits above backgrounds */
  .section--themed > :not(.section__bg) {
    position: relative;
    z-index: 1;
  }

  /* ==================== PROJECTS ==================== */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__category {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.1rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  .project-card__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  /* ==================== SKILLS ==================== */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .skills-cluster {
    border-left: 2px solid var(--color-border-subtle);
    padding-left: var(--space-lg);
  }

  .skills-cluster__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .skills-cluster__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skills-cluster__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== CONTACT ==================== */
  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-2xl);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-base);
    min-width: 160px;
    position: relative;
    overflow: hidden;
  }

  .contact-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(212, 162, 78, 0.12);
  }

  .contact-link span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .contact-link {
      flex: 1;
      min-width: 120px;
      padding: var(--space-lg) var(--space-xl);
    }
    .section__orb {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section__orb,
    .mote {
      animation: none !important;
    }
  }
</style>
