---
/**
 * Index — Portfolio Senior 2026
 *
 * "The Orchestrator" — Personal portfolio with warm palette,
 * distinctive design, real content.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoLayout from '../layouts/BentoLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import SkillsRadar from '../components/interactive/SkillsRadar';
import { projects } from '../data/projects';
import { skillClusters } from '../data/skills';
---

<BaseLayout
  title="David Oliver — Senior Full Stack Developer & AI Solutions Engineer"
  description="Orquestador de sistemas autónomos y ecosistemas digitales. Portfolio técnico 2026."
>
  <!-- ==================== HERO ==================== -->
  <section id="hero" data-animate="fade-in">
    <HeroBlock />
  </section>

  <BentoLayout>
    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" slot="projects">
      <!-- Section background pattern — diagonal circuit lines -->
      <div class="section-bg section-bg--projects" aria-hidden="true">
        <svg class="section-bg__svg" viewBox="0 0 800 600" preserveAspectRatio="none" data-parallax="0.03">
          <line x1="0" y1="100" x2="200" y2="100" stroke="rgba(212,162,78,0.06)" stroke-width="1"/>
          <line x1="200" y1="100" x2="250" y2="50" stroke="rgba(212,162,78,0.06)" stroke-width="1"/>
          <line x1="250" y1="50" x2="500" y2="50" stroke="rgba(212,162,78,0.04)" stroke-width="1"/>
          <circle cx="200" cy="100" r="3" fill="rgba(212,162,78,0.12)"/>
          <circle cx="250" cy="50" r="3" fill="rgba(212,162,78,0.08)"/>
          <line x1="600" y1="400" x2="400" y2="400" stroke="rgba(212,162,78,0.04)" stroke-width="1"/>
          <line x1="400" y1="400" x2="350" y2="450" stroke="rgba(212,162,78,0.06)" stroke-width="1"/>
          <line x1="350" y1="450" x2="100" y2="450" stroke="rgba(212,162,78,0.03)" stroke-width="1"/>
          <circle cx="400" cy="400" r="3" fill="rgba(212,162,78,0.10)"/>
          <circle cx="350" cy="450" r="2" fill="rgba(212,162,78,0.06)"/>
          <line x1="700" y1="200" x2="700" y2="350" stroke="rgba(212,162,78,0.03)" stroke-width="1"/>
          <circle cx="700" cy="200" r="2" fill="rgba(212,162,78,0.08)"/>
        </svg>
      </div>

      <SectionHeader
        number="01."
        title="Proyectos"
        subtitle="Casos reales con impacto medible"
      />

      <div class="projects-grid">
        {projects.filter(p => p.featured).map((project, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <Card variant={project.order === 1 ? 'featured' : 'default'} tag={project.category} href={`/projects/${project.slug}`}>
              <div class="project-card">
                <div class="project-card__category">
                  <span class="project-card__icon" aria-hidden="true">
                    {project.category === 'ai' ? '⚙️' : project.category === 'mobile' ? '📱' : project.category === 'gamedev' ? '🎮' : '🔧'}
                  </span>
                  <Badge variant={project.category === 'ai' ? 'ai' : project.category === 'mobile' ? 'dev' : project.category === 'devops' ? 'infra' : 'default'} size="sm">
                    {project.category}
                  </Badge>
                </div>
                <h3 class="project-card__title">{project.title.es}</h3>
                <p class="project-card__subtitle">{project.subtitle.es}</p>
                <div class="project-card__techs">
                  {project.technologies.slice(0, 4).map(tech => (
                    <span class="project-card__tech">{tech}</span>
                  ))}
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" slot="skills">
      <!-- Section background — orbital rings -->
      <div class="section-bg section-bg--skills" aria-hidden="true">
        <svg class="section-bg__svg" viewBox="0 0 800 500" preserveAspectRatio="none" data-parallax="0.02">
          <ellipse cx="400" cy="250" rx="320" ry="180" fill="none" stroke="rgba(124,149,196,0.05)" stroke-width="1"/>
          <ellipse cx="400" cy="250" rx="220" ry="120" fill="none" stroke="rgba(124,149,196,0.04)" stroke-width="1"/>
          <ellipse cx="400" cy="250" rx="120" ry="60" fill="none" stroke="rgba(124,149,196,0.03)" stroke-width="1"/>
          <circle cx="720" cy="250" r="3" fill="rgba(124,149,196,0.12)"/>
          <circle cx="80" cy="250" r="2" fill="rgba(124,149,196,0.08)"/>
          <circle cx="400" cy="70" r="2" fill="rgba(124,149,196,0.10)"/>
          <circle cx="400" cy="430" r="2" fill="rgba(124,149,196,0.06)"/>
        </svg>
      </div>

      <SectionHeader
        number="02."
        title="Skills"
        subtitle="Clusters semánticos"
      />

      <!-- Interactive cluster cards (React island) -->
      <div data-animate="fade-up" style="--stagger-index: 1">
        <SkillsRadar
          client:visible
          clusters={skillClusters.map(c => ({
            id: c.id,
            label: c.title.es,
            color: c.color,
            skills: c.skills.map(s => ({ name: s.name, level: s.level, cluster: s.cluster })),
          }))}
        />
      </div>

      <!-- Static fallback for no-JS -->
      <noscript>
        <div class="skills-list">
          {skillClusters.map((cluster, ci) => (
            <div class="skills-cluster" data-animate="fade-up" style={`--stagger-index: ${ci}`}>
              <h3 class="skills-cluster__title">
                <span class="skills-cluster__dot" style={`background: ${cluster.color}`} aria-hidden="true"></span>
                {cluster.title.es}
              </h3>
              <div class="skills-cluster__tags">
                {cluster.skills.map(skill => (
                  <Badge variant={cluster.id === 'ai' ? 'ai' : cluster.id === 'development' ? 'dev' : 'infra'} size="sm">
                    {skill.name}
                  </Badge>
                ))}
              </div>
            </div>
          ))}
        </div>
      </noscript>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" slot="experience">
      <!-- Section background — vertical dashed path -->
      <div class="section-bg section-bg--experience" aria-hidden="true">
        <svg class="section-bg__svg" viewBox="0 0 800 600" preserveAspectRatio="none" data-parallax="0.025">
          <line x1="80" y1="0" x2="80" y2="600" stroke="rgba(91,184,166,0.04)" stroke-width="1" stroke-dasharray="4 12"/>
          <circle cx="80" cy="80" r="2" fill="rgba(91,184,166,0.10)"/>
          <circle cx="80" cy="280" r="2" fill="rgba(91,184,166,0.06)"/>
          <circle cx="80" cy="480" r="2" fill="rgba(91,184,166,0.08)"/>
          <line x1="720" y1="100" x2="720" y2="500" stroke="rgba(91,184,166,0.03)" stroke-width="1" stroke-dasharray="4 12"/>
          <circle cx="720" cy="300" r="2" fill="rgba(91,184,166,0.06)"/>
        </svg>
      </div>

      <SectionHeader
        number="03."
        title="Experiencia"
        subtitle="+12 años construyendo software"
      />
      <ExperienceTimeline />
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section id="contact" slot="contact">
      <!-- Section background — convergence lines -->
      <div class="section-bg section-bg--contact" aria-hidden="true">
        <svg class="section-bg__svg" viewBox="0 0 800 400" preserveAspectRatio="none" data-parallax="0.015">
          <line x1="0" y1="200" x2="350" y2="200" stroke="rgba(212,162,78,0.04)" stroke-width="1"/>
          <line x1="800" y1="200" x2="450" y2="200" stroke="rgba(212,162,78,0.04)" stroke-width="1"/>
          <line x1="100" y1="50" x2="380" y2="190" stroke="rgba(212,162,78,0.03)" stroke-width="1"/>
          <line x1="700" y1="350" x2="420" y2="210" stroke="rgba(212,162,78,0.03)" stroke-width="1"/>
          <circle cx="400" cy="200" r="4" fill="rgba(212,162,78,0.10)"/>
          <circle cx="350" cy="200" r="2" fill="rgba(212,162,78,0.06)"/>
          <circle cx="450" cy="200" r="2" fill="rgba(212,162,78,0.06)"/>
        </svg>
      </div>

      <SectionHeader
        number="04."
        title="Contacto"
        subtitle="Hablemos"
        align="center"
      />

      <div class="contact-links" data-animate="fade-up">
        <a
          href="https://github.com/zelinkavo"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="GitHub"
          id="contact-github"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/david-oliver-16729971/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="LinkedIn"
          id="contact-linkedin"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </BentoLayout>
</BaseLayout>

<script>
  /**
   * Section background parallax — lightweight scroll-based movement
   * of decorative SVGs. Mouse parallax on desktop only.
   */
  function initSectionEffects() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');
    if (!parallaxEls.length) return;

    // Scroll parallax — move SVG backgrounds at different rates
    let scrollTicking = false;
    function onScroll() {
      if (scrollTicking) return;
      scrollTicking = true;
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        parallaxEls.forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || '0');
          const section = el.closest('section');
          if (!section) return;
          const rect = section.getBoundingClientRect();
          // Only animate when section is in view
          if (rect.bottom > 0 && rect.top < window.innerHeight) {
            const offset = scrollY * speed * 40;
            el.style.transform = `translateY(${-offset}px)`;
          }
        });
        scrollTicking = false;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mouse parallax — only desktop, only on sections in view
    if (window.innerWidth >= 768) {
      let mouseX = 0, mouseY = 0;
      let currentMX = 0, currentMY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
      });

      function animateMouse() {
        currentMX += (mouseX - currentMX) * 0.04;
        currentMY += (mouseY - currentMY) * 0.04;

        parallaxEls.forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || '0');
          const section = el.closest('section');
          if (!section) return;
          const rect = section.getBoundingClientRect();
          if (rect.bottom > 0 && rect.top < window.innerHeight) {
            const scrollOffset = window.scrollY * speed * 40;
            const mx = currentMX * speed * 60;
            const my = currentMY * speed * 30;
            el.style.transform = `translate(${mx}px, ${-scrollOffset + my}px)`;
          }
        });
        requestAnimationFrame(animateMouse);
      }
      animateMouse();
    }
  }

  document.addEventListener('astro:page-load', initSectionEffects);
  initSectionEffects();
</script>

<style>
  /* ==================== SECTION BASE ==================== */
  section {
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
    position: relative;
    overflow: hidden;
  }

  section#hero {
    padding-top: 0;
    padding-bottom: 0;
  }

  /* Gradient dividers between sections */
  section:not(#hero)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(80%, 600px);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(212, 162, 78, 0.15) 30%,
      rgba(124, 149, 196, 0.15) 70%,
      transparent
    );
  }

  /* ==================== SECTION BACKGROUNDS ==================== */
  .section-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .section-bg__svg {
    position: absolute;
    width: 100%;
    height: 100%;
    will-change: transform;
  }

  /* Projects — circuit lines on right side */
  .section-bg--projects .section-bg__svg {
    right: 0;
    opacity: 1;
  }

  /* Skills — orbital rings centered */
  .section-bg--skills .section-bg__svg {
    opacity: 0.8;
  }

  /* Experience — dashed vertical guides */
  .section-bg--experience .section-bg__svg {
    opacity: 1;
  }

  /* Contact — convergence pattern */
  .section-bg--contact .section-bg__svg {
    opacity: 0.7;
  }

  /* ==================== PROJECTS ==================== */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__category {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.1rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
  }

  .project-card__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  /* ==================== SKILLS (noscript fallback) ==================== */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .skills-cluster {
    border-left: 2px solid var(--color-border-subtle);
    padding-left: var(--space-lg);
  }

  .skills-cluster__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .skills-cluster__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skills-cluster__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== CONTACT ==================== */
  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-2xl);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-base);
    min-width: 160px;
    position: relative;
    overflow: hidden;
  }

  .contact-link::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(212, 162, 78, 0.06);
    filter: blur(30px);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .contact-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(212, 162, 78, 0.12);
  }

  .contact-link:hover::before {
    opacity: 1;
  }

  .contact-link span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .contact-link {
      flex: 1;
      min-width: 120px;
      padding: var(--space-lg) var(--space-xl);
    }
    /* Reduce SVG complexity on mobile */
    .section-bg__svg {
      opacity: 0.5;
    }
  }
</style>
