---
/**
 * Index — Portfolio Senior 2026
 *
 * "The Orchestrator" — Personal portfolio with warm palette,
 * distinctive design, real content.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BentoLayout from '../layouts/BentoLayout.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { projects } from '../data/projects';
import { skillClusters } from '../data/skills';
import { experience } from '../data/experience';
---

<BaseLayout
  title="David Oliver — Senior Full Stack Developer & AI Solutions Engineer"
  description="Orquestador de sistemas autónomos y ecosistemas digitales. Portfolio técnico 2026."
>
  <!-- ==================== HERO (full-bleed) ==================== -->
  <section id="hero" data-animate="fade-in">
    <div class="hero">
      <!-- Subtle grid background -->
      <div class="hero__grid" aria-hidden="true"></div>

      <!-- Warm accent glow (subtle, not orbs) -->
      <div class="hero__glow" aria-hidden="true"></div>

      <div class="hero__content">
        <!-- Monogram "DO" instead of generic avatar -->
        <div class="hero__monogram" data-animate="scale-in">
          <span class="hero__monogram-text" aria-hidden="true">DO</span>
        </div>

        <!-- Title block — clean typography, no rainbow gradient -->
        <div class="hero__title-block">
          <p class="hero__greeting">David Oliver</p>
          <h1 class="hero__title">
            Senior Full Stack Developer
            <span class="hero__amp">&</span>
            AI Solutions Engineer
          </h1>
          <p class="hero__tagline">
            Orquestador de sistemas autónomos y ecosistemas digitales
          </p>
        </div>

        <!-- Experience counter -->
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-value">12+</span>
            <span class="hero__stat-label">años exp.</span>
          </div>
          <div class="hero__stat-divider" aria-hidden="true"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">4</span>
            <span class="hero__stat-label">proyectos</span>
          </div>
          <div class="hero__stat-divider" aria-hidden="true"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">∞</span>
            <span class="hero__stat-label">café</span>
          </div>
        </div>

        <!-- Tech stack — subtle, mono -->
        <div class="hero__stack">
          {['Python', 'TypeScript', 'React', 'Docker', 'Cloudflare'].map((tech, i) => (
            <span class="hero__stack-item" style={`--stagger-index: ${i}`} data-animate="fade-up">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <BentoLayout>
    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" slot="projects">
      <SectionHeader
        number="01."
        title="Proyectos"
        subtitle="Casos reales con impacto medible"
      />

      <div class="projects-grid">
        {projects.filter(p => p.featured).map((project, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <Card variant={project.order === 1 ? 'featured' : 'default'} tag={project.category}>
              <div class="project-card">
                <div class="project-card__category">
                  <span class="project-card__icon" aria-hidden="true">
                    {project.category === 'ai' ? '⚙️' : project.category === 'mobile' ? '📱' : project.category === 'gamedev' ? '🎮' : '🔧'}
                  </span>
                  <Badge variant={project.category === 'ai' ? 'ai' : project.category === 'mobile' ? 'dev' : project.category === 'devops' ? 'infra' : 'default'} size="sm">
                    {project.category}
                  </Badge>
                </div>
                <h3 class="project-card__title">{project.title.es}</h3>
                <p class="project-card__subtitle">{project.subtitle.es}</p>
                <div class="project-card__techs">
                  {project.technologies.slice(0, 4).map(tech => (
                    <span class="project-card__tech">{tech}</span>
                  ))}
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" slot="skills">
      <SectionHeader
        number="02."
        title="Skills"
        subtitle="Clusters semánticos"
      />

      <div class="skills-list">
        {skillClusters.map((cluster, ci) => (
          <div class="skills-cluster" data-animate="fade-up" style={`--stagger-index: ${ci}`}>
            <h3 class="skills-cluster__title">
              <span class="skills-cluster__dot" style={`background: ${cluster.color}`} aria-hidden="true"></span>
              {cluster.title.es}
            </h3>
            <div class="skills-cluster__tags">
              {cluster.skills.map(skill => (
                <Badge variant={cluster.id === 'ai' ? 'ai' : cluster.id === 'development' ? 'dev' : 'infra'} size="sm">
                  {skill.name}
                </Badge>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" slot="experience">
      <SectionHeader
        number="03."
        title="Experiencia"
        subtitle="+12 años construyendo software"
      />

      <div class="timeline">
        {experience.map((entry, i) => (
          <div class="timeline__entry" data-animate="fade-up" style={`--stagger-index: ${i}`}>
            <div class="timeline__marker">
              <div class:list={['timeline__dot', { 'timeline__dot--active': entry.current }]}></div>
              {i < experience.length - 1 && <div class="timeline__line" aria-hidden="true"></div>}
            </div>
            <div class="timeline__content">
              <div class="timeline__header">
                <h3 class="timeline__role">{entry.role.es}</h3>
                <p class="timeline__company">{entry.company}</p>
                <span class="timeline__period">{entry.period.es}</span>
              </div>
              <p class="timeline__description">{entry.description.es}</p>
              <ul class="timeline__achievements">
                {entry.achievements.es.map(a => (
                  <li>{a}</li>
                ))}
              </ul>
              <div class="timeline__techs">
                {entry.technologies.map(tech => (
                  <Badge variant="default" size="sm">{tech}</Badge>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section id="contact" slot="contact">
      <SectionHeader
        number="04."
        title="Contacto"
        subtitle="Hablemos"
        align="center"
      />

      <div class="contact-links" data-animate="fade-up">
        <a
          href="https://github.com/zelinkavo"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="GitHub"
          id="contact-github"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/david-oliver-16729971/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-link"
          aria-label="LinkedIn"
          id="contact-linkedin"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </BentoLayout>
</BaseLayout>

<style>
  /* ==================== HERO ==================== */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    padding: var(--space-3xl) var(--space-xl);
    overflow: hidden;
  }

  /* Subtle dot grid — engineering/blueprint feel */
  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, rgba(212, 162, 78, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 65%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 65%);
  }

  /* Single warm glow — not floating orbs */
  .hero__glow {
    position: absolute;
    width: 600px;
    height: 400px;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse,
      rgba(212, 162, 78, 0.06) 0%,
      rgba(91, 184, 166, 0.03) 40%,
      transparent 70%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
    max-width: 640px;
  }

  /* Monogram — stylized "DO" */
  .hero__monogram {
    width: 88px;
    height: 88px;
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-accent-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-secondary);
    box-shadow: var(--shadow-glow);
  }

  .hero__monogram-text {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-accent-primary);
  }

  /* Title block */
  .hero__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .hero__amp {
    display: block;
    font-size: 0.6em;
    color: var(--color-text-muted);
    font-weight: 400;
    margin: var(--space-xs) 0;
  }

  .hero__tagline {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 440px;
    line-height: 1.7;
    margin: 0 auto;
  }

  /* Stats counter */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-xl);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero__stat-value {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .hero__stat-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero__stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border-subtle);
  }

  /* Tech stack pills */
  .hero__stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .hero__stack-item {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    letter-spacing: 0.02em;
  }

  .hero__stack-item:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
  }

  /* ==================== PROJECTS ==================== */
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: var(--bento-gap);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-card__category {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .project-card__icon {
    font-size: 1.1rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    color: var(--color-text-primary);
  }

  .project-card__subtitle {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  /* ==================== SKILLS ==================== */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .skills-cluster {
    border-left: 2px solid var(--color-border-subtle);
    padding-left: var(--space-lg);
  }

  .skills-cluster__title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .skills-cluster__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skills-cluster__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== EXPERIENCE TIMELINE ==================== */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline__entry {
    display: flex;
    gap: var(--space-lg);
    position: relative;
  }

  .timeline__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--color-text-muted);
    background: var(--color-bg-primary);
    flex-shrink: 0;
    margin-top: 6px;
    z-index: 1;
  }

  .timeline__dot--active {
    border-color: var(--color-accent-primary);
    background: var(--color-accent-primary);
    box-shadow: 0 0 12px rgba(212, 162, 78, 0.4);
  }

  .timeline__line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--color-border-subtle), transparent);
    min-height: var(--space-xl);
  }

  .timeline__content {
    padding-bottom: var(--space-2xl);
    flex: 1;
    min-width: 0;
  }

  .timeline__header {
    margin-bottom: var(--space-sm);
  }

  .timeline__role {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .timeline__company {
    font-size: 0.9rem;
    color: var(--color-accent-secondary);
    margin-bottom: 4px;
  }

  .timeline__period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .timeline__description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: var(--space-sm) 0;
    line-height: 1.6;
  }

  .timeline__achievements {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .timeline__achievements li {
    font-size: 0.825rem;
    color: var(--color-text-secondary);
    padding-left: var(--space-lg);
    position: relative;
    line-height: 1.5;
  }

  .timeline__achievements li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent-primary);
    font-size: 0.8rem;
  }

  .timeline__techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* ==================== CONTACT ==================== */
  .contact-links {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-base);
    min-width: 140px;
  }

  .contact-link:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(212, 162, 78, 0.10);
  }

  .contact-link span {
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ==================== SECTIONS SPACING ==================== */
  section {
    padding-top: var(--section-padding);
    padding-bottom: var(--section-padding);
  }

  section#hero {
    padding-top: 0;
    padding-bottom: 0;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) var(--space-md);
    }

    .hero__monogram {
      width: 72px;
      height: 72px;
    }

    .hero__monogram-text {
      font-size: 1.6rem;
    }

    .hero__stats {
      gap: var(--space-md);
      padding: var(--space-sm) var(--space-lg);
    }

    .hero__stat-value {
      font-size: 1.25rem;
    }

    .contact-link {
      flex: 1;
      min-width: 120px;
    }
  }
</style>
