---
/**
 * BentoLayout.astro — Asymmetric Bento Grid layout
 *
 * Named grid areas for composing the portfolio sections:
 * projects, skills, experience, contact
 *
 * Hero is rendered full-bleed OUTSIDE this grid.
 *
 * Mobile: single column stack
 * Tablet: 2 columns
 * Desktop: asymmetric bento grid
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['bento', className]}>
  <div class="bento__area bento__projects">
    <slot name="projects" />
  </div>

  <div class="bento__area bento__skills">
    <slot name="skills" />
  </div>

  <div class="bento__area bento__experience">
    <slot name="experience" />
  </div>

  <div class="bento__area bento__contact">
    <slot name="contact" />
  </div>
</div>

<style>
  .bento {
    display: grid;
    gap: var(--bento-gap);
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .bento__area {
    min-width: 0; /* prevent grid blowout */
  }

  /*
   * ---- Desktop: Asymmetric Bento Grid ----
   * Layout (Hero is above, outside this grid):
   * ┌──────────────────┬───────────────┐
   * │                  │               │
   * │    PROJECTS      │    SKILLS     │
   * │    (2/3)         │    (1/3)      │
   * │                  │               │
   * ├──────────────────┴───────────────┤
   * │       EXPERIENCE (full width)    │
   * ├──────────────────────────────────┤
   * │        CONTACT (full width)      │
   * └──────────────────────────────────┘
   */
  @media (min-width: 1024px) {
    .bento {
      grid-template-columns: 2fr 1fr;
      grid-template-areas:
        "projects  skills"
        "experience experience"
        "contact   contact";
    }

    .bento__projects   { grid-area: projects; }
    .bento__skills     { grid-area: skills; }
    .bento__experience { grid-area: experience; }
    .bento__contact    { grid-area: contact; }
  }

  /*
   * ---- Tablet: 2 columns ----
   */
  @media (min-width: 768px) and (max-width: 1023px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "projects   projects"
        "skills     experience"
        "contact    contact";
    }

    .bento__projects   { grid-area: projects; }
    .bento__skills     { grid-area: skills; }
    .bento__experience { grid-area: experience; }
    .bento__contact    { grid-area: contact; }
  }

  /*
   * ---- Mobile: Single column ----
   */
  @media (max-width: 767px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "projects"
        "skills"
        "experience"
        "contact";
    }

    .bento__projects   { grid-area: projects; }
    .bento__skills     { grid-area: skills; }
    .bento__experience { grid-area: experience; }
    .bento__contact    { grid-area: contact; }
  }
</style>
