---
/**
 * CaseStudyLayout.astro
 * 
 * Shared layout for individual project detail pages.
 * Integrates directly with BaseLayout.
 */
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  clusters: ('ai' | 'development' | 'infrastructure')[];
  projectContext: string;
  technologies?: string[];
}

const { title, description, clusters, projectContext, technologies = [] } = Astro.props;
---

<BaseLayout title={`${title} — Proyectos | David Oliver`} description={description}>
  
  <article class="case-study section--themed" id="project-top" data-clusters={clusters.join(',')}>
    <!-- Ambient Background -->
    <div class="section__bg section__bg--project" id="project-bg" aria-hidden="true">
      <div class="section__grid section__grid--sparse"></div>
      
      {/* Dynamic Orbs based on clusters */}
      {clusters.includes('ai') && <div class="section__orb section__orb--gold-right"></div>}
      {clusters.includes('development') && <div class="section__orb section__orb--steel-left"></div>}
      {clusters.includes('infrastructure') && <div class="section__orb section__orb--teal-right"></div>}
      
      {/* Canvas particles (spectacular dots and comets, performant) */}
      <canvas class="project__particles" id="project-particles"></canvas>
    </div>

    <div class="content-wrapper">
      <!-- Breadcrumb Nav -->
      <nav class="case-study__nav" aria-label="Breadcrumb">
        <div class="container">
          <a href="/#projects" class="back-link">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Proyectos
          </a>
        </div>
      </nav>

      <!-- Case Study Hero -->
      <header class="case-study__header">
        <div class="container container--narrow text-center">
          <div class="case-study__meta" data-animate="fade-up">
            {clusters.map((cluster) => (
              <Badge variant={cluster === 'ai' ? 'ai' : cluster === 'development' ? 'dev' : 'infra'}>
                {cluster === 'development' ? 'dev' : cluster}
              </Badge>
            ))}
            <span class="case-study__context">{projectContext}</span>
          </div>
        <h1 class="case-study__title" data-animate="fade-up" style="--stagger-index: 1">{title}</h1>
        <p class="case-study__subtitle" data-animate="fade-up" style="--stagger-index: 2">{description}</p>
        
        {technologies.length > 0 && (
          <div class="case-study__tech-stack" data-animate="fade-up" style="--stagger-index: 3">
            {technologies.map((tech) => (
              <span class="tech-badge">{tech}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Case Study Main Content -->
    <main class="case-study__content container container--narrow">
      <slot />
    </main>

    <!-- Bottom Navigation -->
    <footer class="case-study__footer container">
      <div class="footer-nav">
        <a href="/#projects" class="btn btn--secondary">
          ← Volver a Proyectos
        </a>
      </div>
    </footer>
    </div> <!-- end content-wrapper -->
  </article>

</BaseLayout>

<style>
  .container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .container--narrow {
    max-width: 800px;
  }

  .case-study {
    position: relative;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-4xl);
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
  }

  .section__bg--project {
    height: 120vh;
    z-index: -1;
    mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 100%);
    transition: opacity 0.1s linear;
  }

  .project__particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  /* Navigation */
  .case-study__nav {
    margin-bottom: var(--space-2xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent-primary);
  }

  /* Header */
  .case-study__header {
    margin-bottom: var(--space-4xl);
  }

  .case-study__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .case-study__context {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .case-study__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .case-study__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Content / Bento Styles */
  .case-study__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .case-study__content :global(section) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .case-study__content :global(section:hover) {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .case-study__content :global(h2) {
    font-size: 1.75rem;
    color: var(--color-text-primary);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .case-study__content :global(h3) {
    font-size: 1.25rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .case-study__content :global(p) {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .case-study__content :global(ul) {
    list-style: disc;
    padding-left: var(--space-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .case-study__content :global(li) {
    margin-bottom: var(--space-xs);
  }
  
  /* Feature / Highlight Callouts */
  .case-study__content :global(.callout) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent-primary);
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
  }

  /* Footer */
  .case-study__footer {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-nav {
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 var(--space-md);
    }
  }

  .text-center {
    text-align: center;
  }

  /* Back button in footer */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    text-decoration: none;
    line-height: 1;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .btn--secondary {
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .btn--secondary:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-1px);
  }

  /* Tech Stack integrated */
  .case-study__tech-stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: var(--space-xs) var(--space-sm);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .tech-badge:hover {
    color: var(--color-text-primary);
    background: rgba(255,255,255,0.08);
  }

  /* ==================== BACKGROUND ANIMATIONS (Borrowed from Index) ==================== */
  .section__bg {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .section__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
  }

  .section__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .section__orb--gold-right { width: 500px; height: 400px; top: -5%; right: 5%; background: rgba(212, 162, 78, 0.06); animation: orbFloat 16s ease-in-out infinite; }
  .section__orb--steel-left { width: 450px; height: 450px; top: 10%; left: -5%; background: rgba(124, 149, 196, 0.05); animation: orbFloat 18s ease-in-out infinite 3s; }
  .section__orb--teal-right { width: 500px; height: 400px; top: 30%; right: 0%; background: rgba(91, 184, 166, 0.05); animation: orbFloat 20s ease-in-out infinite 5s; }

  @keyframes orbFloat {
    0%   { transform: translate(0, 0); opacity: 1; }
    33%  { transform: translate(15px, -20px); opacity: 0.65; }
    66%  { transform: translate(-12px, -8px); opacity: 0.8; }
    100% { transform: translate(0, 0); opacity: 1; }
  }

  .mote {
    position: absolute;width: 3px;height: 3px;border-radius: 50%;
    animation: moteDrift var(--mote-dur, 20s) ease-in-out infinite;pointer-events: none;
  }
  .mote--lg { width: 5px; height: 5px; }
  .mote--gold { background: rgba(212, 162, 78, 0.5); box-shadow: 0 0 12px rgba(212, 162, 78, 0.25); }
  .mote--steel { background: rgba(124, 149, 196, 0.5); box-shadow: 0 0 12px rgba(124, 149, 196, 0.25); }
  .mote--teal { background: rgba(91, 184, 166, 0.5); box-shadow: 0 0 12px rgba(91, 184, 166, 0.25); }

  @keyframes moteDrift {
    0%   { transform: translate(0, 0); opacity: 0.5; }
    25%  { transform: translate(var(--mote-dx, 10px), var(--mote-dy, -10px)); opacity: 1; }
    50%  { transform: translate(calc(var(--mote-dx, 10px) * -0.5), calc(var(--mote-dy, -10px) * 0.7)); opacity: 0.6; }
    75%  { transform: translate(calc(var(--mote-dx, 10px) * 0.3), calc(var(--mote-dy, -10px) * -0.4)); opacity: 1; }
    100% { transform: translate(0, 0); opacity: 0.5; }
  }

  .comet {
    position: absolute;width: 4px;height: 4px;border-radius: 50%;pointer-events: none;
    animation: cometCross var(--comet-dur, 18s) linear infinite;opacity: 0;
  }
  .comet::after {
    content: '';position: absolute;top: 50%;right: 100%;width: 35px;height: 2px;
    transform: translateY(-50%) rotate(var(--comet-angle, 0deg));transform-origin: right center;border-radius: 2px;
  }
  .comet--gold { background: rgba(212, 162, 78, 0.6); box-shadow: 0 0 8px rgba(212, 162, 78, 0.3); }
  .comet--gold::after { background: linear-gradient(90deg, transparent, rgba(212, 162, 78, 0.35)); }
  .comet--steel { background: rgba(124, 149, 196, 0.6); box-shadow: 0 0 8px rgba(124, 149, 196, 0.3); }
  .comet--steel::after { background: linear-gradient(90deg, transparent, rgba(124, 149, 196, 0.35)); }

  @keyframes cometCross {
    0%   { transform: translate(0, 0); opacity: 0; }
    5%  { opacity: 0.7; }
    45% { opacity: 0.5; }
    50% { transform: translate(var(--comet-tx, 200px), var(--comet-ty, -30px)); opacity: 0.7; }
    95% { opacity: 0.5; }
    98% { opacity: 0; }
    100%{ transform: translate(calc(var(--comet-tx, 200px) * 2), calc(var(--comet-ty, -30px) * 2)); opacity: 0; }
  }
</style>

<script>
  function initProjectParticles() {
    const bgContainer = document.getElementById('project-bg');
    const canvas = document.getElementById('project-particles');
    if (!canvas || !bgContainer) return;
    
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Detect primary color based on active clusters
    const article = document.getElementById('project-top');
    const clustersAttr = article?.getAttribute('data-clusters') || '';
    
    // Default to steel (development), then override if others are present
    let r = 124, g = 149, b = 196; // steel
    if (clustersAttr.includes('ai')) {
      r = 212; g = 162; b = 78; // gold
    } else if (clustersAttr.includes('infrastructure')) {
      r = 91; g = 184; b = 166; // teal
    }
    const colorStr = `${r}, ${g}, ${b}`;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio, 2);
      canvas.width = bgContainer.offsetWidth * dpr;
      canvas.height = bgContainer.offsetHeight * dpr;
      ctx.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', resize);

    const PARTICLE_COUNT = 30; // Slightly fewer than hero
    const COMET_COUNT = 6;
    const particles = [];
    const w = () => bgContainer.offsetWidth;
    const h = () => bgContainer.offsetHeight;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      const isComet = i < COMET_COUNT;
      const goesRight = isComet ? (i % 2 === 0) : true;
      particles.push({
        x: Math.random() * w(),
        y: Math.random() * h(),
        baseY: Math.random() * h(),
        size: isComet ? 2 + Math.random() * 2 : 1.5 + Math.random() * 2.5,
        speed: isComet ? 0.2 + Math.random() * 0.2 : 0.1 + Math.random() * 0.3,
        opacity: isComet ? 0.3 + Math.random() * 0.3 : 0.1 + Math.random() * 0.3,
        phase: Math.random() * Math.PI * 2,
        drift: isComet
          ? (goesRight ? 1 : -1) * (0.5 + Math.random() * 0.6)
          : (Math.random() - 0.5) * 0.2,
        isComet,
        trail: [],
      });
    }

    let frameCount = 0;
    let animationId;
    let currentOpacity = 1;

    function drawParticles() {
      // Don't draw if invisible due to scroll
      if (currentOpacity <= 0) {
        animationId = requestAnimationFrame(drawParticles);
        return;
      }
      
      ctx.clearRect(0, 0, w(), h());
      frameCount++;

      for (const p of particles) {
        const prevX = p.x;
        const prevY = p.y;
        p.y = p.baseY + Math.sin(frameCount * 0.008 * p.speed + p.phase) * 25;
        p.x += p.drift;

        if (p.x < -10) { p.x = w() + 10; p.trail = []; }
        if (p.x > w() + 10) { p.x = -10; p.trail = []; }

        const pulse = 0.7 + 0.3 * Math.sin(frameCount * 0.012 + p.phase);

        if (p.isComet) {
          p.trail.push({ x: p.x, y: p.y });
          if (p.trail.length > 45) p.trail.shift();

          if (p.trail.length > 2) {
            const len = p.trail.length;
            for (let t = 1; t < len; t++) {
              const progress = t / len;
              const alpha = progress * p.opacity * pulse * 0.8 * currentOpacity;
              const lineWidth = p.size * progress * 1.2;
              ctx.beginPath();
              ctx.moveTo(p.trail[t - 1].x, p.trail[t - 1].y);
              ctx.lineTo(p.trail[t].x, p.trail[t].y);
              ctx.strokeStyle = `rgba(${colorStr}, ${alpha})`;
              ctx.lineWidth = lineWidth;
              ctx.lineCap = 'round';
              ctx.stroke();
            }
          }

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${colorStr}, ${p.opacity * pulse * 0.2 * currentOpacity})`;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${colorStr}, ${p.opacity * pulse * currentOpacity})`;
        ctx.fill();

        if (!p.isComet && p.size > 2.5) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${colorStr}, ${p.opacity * pulse * 0.1 * currentOpacity})`;
          ctx.fill();
        }
      }
      animationId = requestAnimationFrame(drawParticles);
    }
    
    drawParticles();

    // Scroll opacity fade
    function updateScrollFade() {
      const scrollMax = Math.min(window.innerHeight * 0.8, 800);
      const scrollY = window.scrollY;
      
      // Calculate opacity from 1 to 0 based on scroll depth
      let newOpacity = 1 - (scrollY / scrollMax);
      newOpacity = Math.max(0, Math.min(1, newOpacity));
      
      // Reduce intensity
      currentOpacity = newOpacity;
      // We also dim the whole background block gradually
      bgContainer.style.opacity = String(0.2 + (0.8 * newOpacity)); 
    }
    
    window.addEventListener('scroll', updateScrollFade, { passive: true });
    updateScrollFade();
  }

  document.addEventListener('astro:page-load', initProjectParticles);
  initProjectParticles();
</script>
