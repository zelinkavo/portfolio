---
/**
 * CaseStudyLayout.astro
 * 
 * Shared layout for individual project detail pages.
 * Integrates directly with BaseLayout.
 */
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  clusters: ('ai' | 'development' | 'infrastructure')[];
  projectContext: string;
  technologies?: string[];
}

const { title, description, clusters, projectContext, technologies = [] } = Astro.props;
---

<BaseLayout title={`${title} — Proyectos | David Oliver`} description={description}>
  
  <article class="case-study section--themed" id="project-top" data-clusters={clusters.join(',')}>
    <div class="section__bg section__bg--project" aria-hidden="true">
      <div class="section__grid section__grid--sparse"></div>
      
      {/* Dynamic Orbs based on clusters */}
      {clusters.includes('ai') && <div class="section__orb section__orb--gold-right"></div>}
      {clusters.includes('development') && <div class="section__orb section__orb--steel-left"></div>}
      {clusters.includes('infrastructure') && <div class="section__orb section__orb--teal-right"></div>}
      
      {/* Very High Density Top (Hero area) - 0% to 25% height */}
      <div class={`mote ${clusters.includes('ai') ? 'mote--gold' : 'mote--steel'}`} style="top:5%;left:12%;--mote-dur:18s;--mote-dx:20px;--mote-dy:-15px"></div>
      <div class={`mote ${clusters.includes('development') ? 'mote--steel' : 'mote--teal'}`} style="top:15%;right:18%;--mote-dur:22s;--mote-dx:-12px;--mote-dy:18px;animation-delay:-5s"></div>
      <div class={`mote ${clusters.includes('infrastructure') ? 'mote--teal' : 'mote--gold'} mote--lg`} style="top:8%;right:35%;--mote-dur:24s;--mote-dx:-8px;--mote-dy:12px;animation-delay:-12s"></div>
      <div class={`mote ${clusters.includes('ai') ? 'mote--gold' : 'mote--steel'}`} style="top:20%;left:28%;--mote-dur:16s;--mote-dx:15px;--mote-dy:-10px;animation-delay:-3s"></div>
      <div class={`mote ${clusters.includes('development') ? 'mote--steel' : 'mote--teal'}`} style="top:22%;right:45%;--mote-dur:20s;--mote-dx:-15px;--mote-dy:-12px;animation-delay:-8s"></div>
      <div class={`mote ${clusters.includes('infrastructure') ? 'mote--teal' : 'mote--gold'}`} style="top:2%;left:60%;--mote-dur:25s;--mote-dx:12px;--mote-dy:18px;animation-delay:-15s"></div>
      
      <div class={`comet ${clusters.includes('ai') ? 'comet--gold' : 'comet--steel'}`} style="top:8%;left:5%;--comet-dur:14s;--comet-tx:300px;--comet-ty:-25px;--comet-angle:-6deg"></div>
      <div class={`comet ${clusters.includes('development') ? 'comet--steel' : 'comet--teal'} comet--reverse`} style="top:18%;right:5%;--comet-dur:16s;--comet-tx:-250px;--comet-ty:-15px;--comet-angle:4deg;animation-delay:-5s"></div>
      <div class={`comet ${clusters.includes('infrastructure') ? 'comet--teal' : 'comet--gold'}`} style="top:25%;left:2%;--comet-dur:22s;--comet-tx:350px;--comet-ty:-35px;--comet-angle:-8deg;animation-delay:-10s"></div>
      
      {/* Medium Density Middle (Content) - 25% to 65% height */}
      <div class={`mote ${clusters.includes('development') ? 'mote--steel' : 'mote--gold'}`} style="top:40%;left:25%;--mote-dur:20s;--mote-dx:15px;--mote-dy:-10px;animation-delay:-8s"></div>
      <div class={`mote ${clusters.includes('ai') ? 'mote--gold' : 'mote--steel'} mote--lg`} style="top:50%;left:75%;--mote-dur:28s;--mote-dx:-20px;--mote-dy:15px;animation-delay:-2s"></div>
      <div class={`mote ${clusters.includes('infrastructure') ? 'mote--teal' : 'mote--steel'}`} style="top:60%;right:22%;--mote-dur:26s;--mote-dx:-18px;--mote-dy:14px;animation-delay:-13s"></div>
      
      <div class={`comet ${clusters.includes('development') ? 'comet--steel' : 'comet--teal'} comet--reverse`} style="top:55%;right:10%;--comet-dur:20s;--comet-tx:-200px;--comet-ty:-25px;--comet-angle:8deg;animation-delay:-7s"></div>

      {/* Low Density Bottom (Footer area) - 65% to 100% height */}
      <div class={`mote ${clusters.includes('ai') ? 'mote--gold' : 'mote--teal'} mote--lg`} style="top:85%;left:45%;--mote-dur:30s;--mote-dx:-10px;--mote-dy:-15px;animation-delay:-16s"></div>
    </div>

    <div class="content-wrapper">
      <!-- Breadcrumb Nav -->
      <nav class="case-study__nav" aria-label="Breadcrumb">
        <div class="container">
          <a href="/#projects" class="back-link">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Proyectos
          </a>
        </div>
      </nav>

      <!-- Case Study Hero -->
      <header class="case-study__header" id="project-parallax">
        
        {/* Layer 1: The Translucent Nebula (Orbs behind the text) */}
        <div class="project__layer project__layer--orbs" data-depth="0.04" aria-hidden="true">
          {clusters.includes('ai') && <div class="project-orb project-orb--gold"></div>}
          {clusters.includes('development') && <div class="project-orb project-orb--steel"></div>}
          {clusters.includes('infrastructure') && <div class="project-orb project-orb--teal"></div>}
        </div>

        {/* Layer 2: The Text Content */}
        <div class="project__layer project__layer--content" data-depth="0.07">
          <div class="container container--narrow text-center project__content-inner">
            <div class="case-study__meta" data-animate="fade-up">
              {clusters.map((cluster) => (
                <Badge variant={cluster === 'ai' ? 'ai' : cluster === 'development' ? 'dev' : 'infra'}>
                  {cluster === 'development' ? 'dev' : cluster}
                </Badge>
              ))}
              <span class="case-study__context">{projectContext}</span>
            </div>
            <h1 class="case-study__title" data-animate="fade-up" style="--stagger-index: 1">{title}</h1>
            <p class="case-study__subtitle" data-animate="fade-up" style="--stagger-index: 2">{description}</p>
            
            {technologies.length > 0 && (
              <div class="case-study__tech-stack" data-animate="fade-up" style="--stagger-index: 3">
                {technologies.map((tech) => (
                  <span class="tech-badge">{tech}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </header>

    <!-- Case Study Main Content -->
    <main class="case-study__content container container--narrow">
      <slot />
    </main>

    <!-- Bottom Navigation -->
    <footer class="case-study__footer container">
      <div class="footer-nav">
        <a href="/#projects" class="btn btn--secondary">
          ← Volver a Proyectos
        </a>
      </div>
    </footer>
    </div> <!-- end content-wrapper -->
  </article>

</BaseLayout>

<style>
  .container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .container--narrow {
    max-width: 800px;
  }

  .case-study {
    position: relative;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-4xl);
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
  }

  .section__bg--project {
    height: 100%;
    z-index: 0;
  }

  /* Navigation */
  .case-study__nav {
    margin-bottom: var(--space-2xl);
    position: relative;
    z-index: 5;
  }

  /* Header / Parallax Scope */
  .case-study__header {
    position: relative;
    padding: var(--space-xl) 0 var(--space-4xl);
  }

  /* Parallax Layers */
  .project__layer {
    will-change: transform;
  }
  
  .project__layer--orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  
  .project__layer--content {
    position: relative;
    z-index: 2;
  }

  /* Inner wrapper for CSS float animation */
  .project__content-inner {
    animation: contentFloat 8s ease-in-out infinite;
  }
  
  @keyframes contentFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* Nebulosa circular translúcida (Orbs) */
  .project-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .project-orb--gold {
    width: 600px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(212, 162, 78, 0.08);
    animation: orbFloatPulse 12s ease-in-out infinite;
  }

  .project-orb--steel {
    width: 500px;
    height: 350px;
    top: 50%;
    left: 45%;
    transform: translate(-50%, -50%);
    background: rgba(124, 149, 196, 0.07);
    animation: orbDriftPulse 14s ease-in-out infinite 2s;
  }

  .project-orb--teal {
    width: 500px;
    height: 350px;
    top: 50%;
    left: 55%;
    transform: translate(-50%, -50%);
    background: rgba(91, 184, 166, 0.07);
    animation: orbDriftPulse 16s ease-in-out infinite 5s;
  }

  @keyframes orbFloatPulse {
    0%   { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    50%  { transform: translate(-50%, -52%) scale(1.05); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  }

  @keyframes orbDriftPulse {
    0%   { transform: translate(-50%, -50%); opacity: 1; }
    50%  { transform: translate(-48%, -48%); opacity: 0.85; }
    100% { transform: translate(-50%, -50%); opacity: 1; }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent-primary);
  }

  /* Header */
  .case-study__header {
    margin-bottom: var(--space-4xl);
  }

  .case-study__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .case-study__context {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .case-study__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .case-study__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Content / Bento Styles */
  .case-study__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .case-study__content :global(section) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .case-study__content :global(section:hover) {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .case-study__content :global(h2) {
    font-size: 1.75rem;
    color: var(--color-text-primary);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .case-study__content :global(h3) {
    font-size: 1.25rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .case-study__content :global(p) {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .case-study__content :global(ul) {
    list-style: disc;
    padding-left: var(--space-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .case-study__content :global(li) {
    margin-bottom: var(--space-xs);
  }
  
  /* Feature / Highlight Callouts */
  .case-study__content :global(.callout) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-left: 4px solid var(--color-accent-primary);
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
  }

  /* Footer */
  .case-study__footer {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-nav {
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 var(--space-md);
    }
  }

  .text-center {
    text-align: center;
  }

  /* Back button in footer */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    text-decoration: none;
    line-height: 1;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .btn--secondary {
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .btn--secondary:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-1px);
  }

  /* Tech Stack integrated */
  .case-study__tech-stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: var(--space-xs) var(--space-sm);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .tech-badge:hover {
    color: var(--color-text-primary);
    background: rgba(255,255,255,0.08);
  }

  /* ==================== BACKGROUND ANIMATIONS (Borrowed from Index) ==================== */
  .section__bg {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .section__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
  }

  .section__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .section__orb--gold-right { width: 500px; height: 400px; top: -5%; right: 5%; background: rgba(212, 162, 78, 0.06); animation: orbFloat 16s ease-in-out infinite; }
  .section__orb--steel-left { width: 450px; height: 450px; top: 10%; left: -5%; background: rgba(124, 149, 196, 0.05); animation: orbFloat 18s ease-in-out infinite 3s; }
  .section__orb--teal-right { width: 500px; height: 400px; top: 30%; right: 0%; background: rgba(91, 184, 166, 0.05); animation: orbFloat 20s ease-in-out infinite 5s; }

  @keyframes orbFloat {
    0%   { transform: translate(0, 0); opacity: 1; }
    33%  { transform: translate(15px, -20px); opacity: 0.65; }
    66%  { transform: translate(-12px, -8px); opacity: 0.8; }
    100% { transform: translate(0, 0); opacity: 1; }
  }

  .mote {
    position: absolute;width: 3px;height: 3px;border-radius: 50%;
    animation: moteDrift var(--mote-dur, 20s) ease-in-out infinite;pointer-events: none;
  }
  .mote--lg { width: 5px; height: 5px; }
  .mote--gold { background: rgba(212, 162, 78, 0.5); box-shadow: 0 0 12px rgba(212, 162, 78, 0.25); }
  .mote--steel { background: rgba(124, 149, 196, 0.5); box-shadow: 0 0 12px rgba(124, 149, 196, 0.25); }
  .mote--teal { background: rgba(91, 184, 166, 0.5); box-shadow: 0 0 12px rgba(91, 184, 166, 0.25); }

  @keyframes moteDrift {
    0%   { transform: translate(0, 0); opacity: 0.5; }
    25%  { transform: translate(var(--mote-dx, 10px), var(--mote-dy, -10px)); opacity: 1; }
    50%  { transform: translate(calc(var(--mote-dx, 10px) * -0.5), calc(var(--mote-dy, -10px) * 0.7)); opacity: 0.6; }
    75%  { transform: translate(calc(var(--mote-dx, 10px) * 0.3), calc(var(--mote-dy, -10px) * -0.4)); opacity: 1; }
    100% { transform: translate(0, 0); opacity: 0.5; }
  }

  .comet {
    position: absolute;width: 4px;height: 4px;border-radius: 50%;pointer-events: none;
    animation: cometCross var(--comet-dur, 18s) linear infinite;opacity: 0;
  }
  .comet::after {
    content: '';position: absolute;top: 50%;right: 100%;width: 35px;height: 2px;
    transform: translateY(-50%) rotate(var(--comet-angle, 0deg));transform-origin: right center;border-radius: 2px;
  }
  .comet--gold { background: rgba(212, 162, 78, 0.6); box-shadow: 0 0 8px rgba(212, 162, 78, 0.3); }
  .comet--gold::after { background: linear-gradient(90deg, transparent, rgba(212, 162, 78, 0.35)); }
  .comet--steel { background: rgba(124, 149, 196, 0.6); box-shadow: 0 0 8px rgba(124, 149, 196, 0.3); }
  .comet--steel::after { background: linear-gradient(90deg, transparent, rgba(124, 149, 196, 0.35)); }
  .comet--teal { background: rgba(91, 184, 166, 0.6); box-shadow: 0 0 8px rgba(91, 184, 166, 0.3); }
  .comet--teal::after { background: linear-gradient(90deg, transparent, rgba(91, 184, 166, 0.35)); }

  /* Reverse tail for comets moving right-to-left */
  .comet--reverse::after {
    right: auto;
    left: 100%;
    transform-origin: left center;
  }
  .comet--reverse.comet--gold::after { background: linear-gradient(90deg, rgba(212, 162, 78, 0.35), transparent); }
  .comet--reverse.comet--steel::after { background: linear-gradient(90deg, rgba(124, 149, 196, 0.35), transparent); }
  .comet--reverse.comet--teal::after { background: linear-gradient(90deg, rgba(91, 184, 166, 0.35), transparent); }

  @keyframes cometCross {
    0%   { transform: translate(0, 0); opacity: 0; }
    5%  { opacity: 0.7; }
    45% { opacity: 0.5; }
    50% { transform: translate(var(--comet-tx, 200px), var(--comet-ty, -30px)); opacity: 0.7; }
    95% { opacity: 0.5; }
    98% { opacity: 0; }
    100%{ transform: translate(calc(var(--comet-tx, 200px) * 2), calc(var(--comet-ty, -30px) * 2)); opacity: 0; }
  }
</style>

<script>
  function initProjectParallax() {
    const hero = document.getElementById('project-parallax');
    if (!hero) return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced && window.innerWidth >= 768) {
      const layers = hero.querySelectorAll<HTMLElement>('[data-depth]');
      let targetX = 0, targetY = 0, currentX = 0, currentY = 0;

      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        targetX = (e.clientX - rect.left - rect.width / 2) / rect.width;
        targetY = (e.clientY - rect.top - rect.height / 2) / rect.height;
      });

      hero.addEventListener('mouseleave', () => {
        targetX = 0;
        targetY = 0;
      });

      function animateParallax() {
        currentX += (targetX - currentX) * 0.06;
        currentY += (targetY - currentY) * 0.06;
        layers.forEach((layer) => {
          const depth = parseFloat(layer.dataset.depth || '0');
          layer.style.transform = `translate(${currentX * depth * 80}px, ${currentY * depth * 50}px)`;
        });
        requestAnimationFrame(animateParallax);
      }
      animateParallax();
    }
  }

  document.addEventListener('astro:page-load', initProjectParallax);
  initProjectParallax();
</script>
